
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isMember(companyId) {
        return exists(/databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid));
    }
    
    function isAdmin() {
      // Super admin UIDs can bypass document reads during seeding.
      let isSuperAdmin = request.auth.uid in ['i947NWP5Hfb3Tpe5P6XcrjODRIJ2', '8ulGMzDhV1VgocwqptGCpV6Dkkl1'];
      // Check for 'Admin' role in the user's profile for regular operations.
      let isRoleAdmin = isSignedIn() && getUserData().role == 'Admin';
      return isSuperAdmin || isRoleAdmin;
    }

    // --- User Profiles ---
    match /users/{userId} {
      // Users can read/write their own profile. Admins can read/write any profile.
      allow read, write: if isOwner(userId) || isAdmin();
      // Admins can list all users.
      allow list: if isAdmin();
    }
    
    // --- Company Data ---
    match /companies/{companyId}/{document=**} {
        // Members of a company can read its data. Admins can do anything.
        allow read: if isMember(companyId);
        allow write: if isAdmin();
    }
    
    // Explicit rule for listing companies for logged-in users (e.g., in directories)
    match /companies/{companyId} {
        allow list: if isSignedIn();
    }
    
    // --- Collection Group Queries ---
    match /{path=**}/bids/{bidId} {
      // Allow an inspector to query for their own bids across all jobs.
      allow list: if isSignedIn() && request.query.where[0] == 'inspectorId' && request.query.where[2] == request.auth.uid;
    }
    
    // --- Admin-only & Catalog Collections ---
    match /admin/{collection}/{docId} {
        allow read, write: if isAdmin();
    }
    
    match /catalog/{category}/{docId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
    }
  }
}
