
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // This is the definitive way to check for admin.
    // UIDs are for admin@ndtexchange.com and seyonnexalabs@gmail.com
    function isAdmin() {
      return isSignedIn() && (request.auth.uid == 'i947NWP5Hfb3Tpe5P6XcrjODRIJ2' || request.auth.uid == '8ulGMzDhV1VgocwqptGCpV6Dkkl1');
    }

    // --------------------------------
    // Collection Rules
    // --------------------------------

    match /users/{userId} {
      // Any authenticated user can create their own user document during signup. Admins can create any.
      allow create: if isOwner(userId) || isAdmin();
      // Users can only read their own profile. Admins can read any.
      allow get: if isOwner(userId) || isAdmin();
      // Users can only be listed by admins.
      allow list: if isAdmin();
      // Users can only update their own profile. Admins can update any.
      allow update: if isOwner(userId) || isAdmin();
      // Only admins can delete users.
      allow delete: if isAdmin();
    }

    match /companies/{companyId} {
      // Admins or the initial company contact can create a company document.
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.contactEmail == request.auth.token.email);
      // All company documents are publicly readable.
      allow read: if true;
      // Only admins can modify company data.
      allow write: if isAdmin();

      match /supportChats/{chatId} {
        // Only members of the company or admins can access support chats.
        // This relies on a custom claim or client-side check, as get() is removed.
        allow read, write: if isSignedIn();
        
        match /supportMessages/{messageId} {
          allow read, write: if isSignedIn();
        }
      }
    }
    
    match /assets/{assetId} {
      // Any signed-in user can create assets, linking it to their companyId.
      allow create: if isSignedIn() && request.resource.data.companyId == request.auth.token.companyId;
      // You can only read/update/delete an asset if your companyId matches the asset's companyId.
      allow read, update, delete: if isSignedIn() && resource.data.companyId == request.auth.token.companyId;
      
      match /inspections/{inspectionId} {
        // Any signed-in user can create an inspection.
        allow create: if isSignedIn();
        // You can read an inspection if you are the inspector or a member of the asset's owning company.
        allow read: if isOwner(resource.data.inspectorId) || resource.data.assetOwnerCompanyId == request.auth.token.companyId;
        // Only the assigned inspector or an admin can update/delete.
        allow update, delete: if isAdmin() || isOwner(resource.data.inspectorId);
      }
    }

    match /jobs/{jobId} {
      // A signed-in user can create a job if they are the client.
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.clientId == request.auth.uid);
      // All jobs are publicly readable.
      allow read: if true;
      // Only the client, the awarded provider, or an admin can update a job.
      allow update: if isAdmin() || request.auth.token.companyId == resource.data.clientCompanyId || request.auth.token.companyId == resource.data.awardedProviderId;
      // Only the client or an admin can delete a job.
      allow delete: if isAdmin() || request.auth.token.companyId == resource.data.clientCompanyId;

      match /bids/{bidId} {
        // An inspector can create a bid.
        allow create: if isSignedIn() && request.resource.data.inspectorId == request.auth.uid;
        // The job client, the bidding inspector, or an admin can read bids.
        allow read: if isAdmin() || isOwner(resource.data.inspectorId) || request.auth.token.companyId == get(/databases/$(database)/documents/jobs/$(jobId)).data.clientCompanyId;
        // Only the bidding inspector or an admin can update/delete.
        allow update, delete: if isAdmin() || isOwner(resource.data.inspectorId);
      }
      
      match /messages/{messageId} {
        // Participants of the job or admins can read/write messages.
        allow read, write: if isSignedIn() && (
          request.auth.token.companyId == get(/databases/$(database)/documents/jobs/$(jobId)).data.clientCompanyId ||
          request.auth.token.companyId == get(/databases/$(database)/documents/jobs/$(jobId)).data.awardedProviderId
        ) || isAdmin();
      }
    }

    match /reports/{reportId} {
      // Any signed-in user can create a report document.
      allow create: if isSignedIn();
      // Access to reports is determined by involvement in the job/asset.
      allow read: if isSignedIn();
      allow update, delete: if isAdmin() || isOwner(resource.data.inspectorId);
    }
    
    // All other collections that are either public or admin-only
    match /asset_types/{assetTypeId} { allow read: if true; allow write: if isAdmin(); }
    match /techniques/{techniqueId} { allow read: if true; allow write: if isAdmin(); }
    match /manufacturers/{manufacturerId} { allow read: if true; allow write: if isAdmin(); }
    match /equipment/{equipmentId} { allow read: if true; allow write: if isAdmin(); }
    match /defects/{defectId} { allow read, write: if isAdmin(); }
    match /subscriptions/{subscriptionId} { allow read, write: if isAdmin(); }
    match /roles_admin/{userId} { allow read, write: if isAdmin(); }
    match /payments/{paymentId} { allow read, write: if isAdmin(); }
    match /jobPayments/{paymentId} { allow read, write: if isAdmin(); }
    match /reviews/{reviewId} { allow read: if true; allow create: if isSignedIn(); allow write: if isAdmin(); }
    match /userAuditLogs/{logId} { allow read, write: if isAdmin(); }
    match /jobAuditLogs/{logId} { allow read, write: if isAdmin(); }
    match /billingAuditLogs/{logId} { allow read, write: if isAdmin(); }
  }
}
