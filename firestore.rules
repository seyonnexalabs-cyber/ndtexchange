
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // This is the definitive way to check for admin.
    // UIDs are for admin@ndtexchange.com and seyonnexalabs@gmail.com
    function isAdmin() {
      return isSignedIn() && (request.auth.uid == 'i947NWP5Hfb3Tpe5P6XcrjODRIJ2' || request.auth.uid == '8ulGMzDhV1VgocwqptGCpV6Dkkl1');
    }

    // Helper to get a user's company ID. This is more efficient than getting the whole user profile.
    function userCompanyId(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.companyId;
    }

    // Helper function to check if a user is part of a job's client or provider company
    function isJobParticipant(jobId) {
      let job = get(/databases/$(database)/documents/jobs/$(jobId)).data;
      return exists(/databases/$(database)/documents/jobs/$(jobId)) &&
             (job.clientCompanyId == userCompanyId(request.auth.uid) ||
             (job.providerId != null && job.providerId == userCompanyId(request.auth.uid)));
    }

    // --------------------------------
    // Collection Rules
    // --------------------------------

    match /users/{userId} {
      allow write: if isAdmin(); // Admin can seed
      allow create: if isOwner(userId);
      allow get: if isSignedIn();
      allow update, delete: if isOwner(userId);
      allow list: if true; // WARNING: Overly permissive for demo. In production, restrict to admins or specific queries.

      // FCM tokens can only be managed by the owner
      match /fcmTokens/{token} {
        allow read, write: if isOwner(userId);
      }

      // Notifications can only be read and updated by the owner
      match /notifications/{notificationId} {
        allow write: if isAdmin();
        allow read, update: if isOwner(userId);
      }
      
      match /tasks/{taskId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /companies/{companyId} {
      allow write: if isAdmin(); // Admin can seed
      // Admins or the initial company contact can create a company document.
      allow create: if (isSignedIn() && request.resource.data.contactEmail == request.auth.token.email);
      // All company documents are readable by any signed in user.
      allow read, list: if true;
      // Only admins can modify company data.
      allow update: if isAdmin();

      match /supportChats/{chatId} {
        // Allow members of the company or admins to access support chats.
        allow read, write: if userCompanyId(request.auth.uid) == companyId || isAdmin();
        
        match /supportMessages/{messageId} {
          allow read, write: if userCompanyId(request.auth.uid) == companyId || isAdmin();
        }
      }
    }
    
    match /assets/{assetId} {
      allow write: if isAdmin(); // Admin can seed
      // A user can create an asset for their own company.
      allow create: if (isSignedIn() && request.resource.data.companyId == userCompanyId(request.auth.uid));
      // Listing is allowed, and secured by client-side queries.
      allow list: if isSignedIn();
      // A user can read, update, or delete an asset IFF they belong to that asset's company.
      allow get, update, delete: if (isSignedIn() && (userCompanyId(request.auth.uid) == resource.data.companyId || isAdmin()));
      
      match /inspections/{inspectionId} {
        allow write: if isAdmin(); // Admin can seed
        // Creating an inspection is allowed if you are a member of the asset's company.
        allow create: if (isSignedIn() && get(/databases/$(database)/documents/assets/$(assetId)).data.companyId == userCompanyId(request.auth.uid));
        // You can get/list an inspection if you are the inspector or a member of the asset's owning company.
        allow get, list: if isSignedIn() && (isOwner(resource.data.inspectorId) || get(/databases/$(database)/documents/assets/$(assetId)).data.companyId == userCompanyId(request.auth.uid));
        // Only the assigned inspector or an admin can update/delete.
        allow update, delete: if isOwner(resource.data.inspectorId) || isAdmin();
      }
    }

    // Rule to allow inspectors to query their own bids across all jobs.
    match /{path=**}/bids/{bidId} {
      allow list: if request.auth.uid == resource.data.inspectorId;
      allow get: if (isSignedIn() && (
                        isOwner(resource.data.inspectorId) || 
                        userCompanyId(request.auth.uid) == get(/databases/$(database)/documents/jobs/$(path[1])).data.clientCompanyId
                      )) || isAdmin();
    }
    
    match /{path=**}/supportChats/{chatId} {
      // Allow admins to query across all company support chats
      allow read: if isAdmin();
    }

    match /jobs/{jobId} {
      allow write: if isAdmin(); // Admin can seed
      // A signed-in user can create a job if they are the client.
      allow create: if (isSignedIn() && (request.resource.data.clientId == request.auth.uid || request.resource.data.clientCompanyId == userCompanyId(request.auth.uid)));
      
      // Allow LISTING jobs for marketplace browsing
      allow list: if isSignedIn();
      
      // Allow GETTING a job's details
      allow get: if (isSignedIn() && (
                      resource.data.status == 'Posted' || // Anyone can see open jobs
                      userCompanyId(request.auth.uid) == resource.data.clientCompanyId ||
                      userCompanyId(request.auth.uid) == resource.data.companyId || // legacy support
                      (exists(/databases/$(database)/documents/companies/$(userCompanyId(request.auth.uid))) && get(/databases/$(database)/documents/companies/$(userCompanyId(request.auth.uid))).data.type == 'Provider' && userCompanyId(request.auth.uid) == resource.data.providerId)
                    )) || isAdmin();

      // Only the client, the awarded provider, or an admin can update a job.
      allow update: if (isSignedIn() && (
                        userCompanyId(request.auth.uid) == resource.data.clientCompanyId ||
                        userCompanyId(request.auth.uid) == resource.data.companyId || // legacy support
                        (exists(/databases/$(database)/documents/companies/$(userCompanyId(request.auth.uid))) && get(/databases/$(database)/documents/companies/$(userCompanyId(request.auth.uid))).data.type == 'Provider' && userCompanyId(request.auth.uid) == resource.data.providerId)
                      )) || isAdmin();

      // Only the client or an admin can delete a job.
      allow delete: if (isSignedIn() && 
                       (userCompanyId(request.auth.uid) == resource.data.clientCompanyId || userCompanyId(request.auth.uid) == resource.data.companyId)
                      ) || isAdmin();

      match /bids/{bidId} {
        allow write: if isAdmin(); // Admin can seed
        // An inspector can create a bid for their own user ID.
        allow create: if (isSignedIn() && request.resource.data.inspectorId == request.auth.uid);

        // GET allows the job client or the bidding inspector to read a single bid.
        allow get: if (isSignedIn() && (
                        isOwner(resource.data.inspectorId) || 
                        userCompanyId(request.auth.uid) == get(/databases/$(database)/documents/jobs/$(jobId)).data.clientCompanyId
                      )) || isAdmin();

        // LIST allows the job client to read all bids for their job.
        allow list: if (isSignedIn() && 
                        userCompanyId(request.auth.uid) == get(/databases/$(database)/documents/jobs/$(jobId)).data.clientCompanyId
                      ) || isAdmin();
                      
        allow update: if (isSignedIn() && (
                      userCompanyId(request.auth.uid) == userCompanyId(resource.data.inspectorId) ||
                      get(/databases/$(database)/documents/jobs/$(jobId)).data.clientCompanyId == userCompanyId(request.auth.uid)
                    ));
        allow delete: if isSignedIn() && userCompanyId(request.auth.uid) == userCompanyId(resource.data.inspectorId);
      }
      
      match /messages/{messageId} {
        allow write: if isAdmin(); // Admin can seed
        // Participants of the job can read messages and create new ones.
        allow read, create: if (isSignedIn() && (
            exists(/databases/$(database)/documents/jobs/$(jobId)) && (
                userCompanyId(request.auth.uid) == get(/databases/$(database)/documents/jobs/$(jobId)).data.clientCompanyId ||
                (get(/databases/$(database)/documents/jobs/$(jobId)).data.providerId != null && userCompanyId(request.auth.uid) == get(/databases/$(database)/documents/jobs/$(jobId)).data.providerId)
              )
            )) || isAdmin();
      }
    }

    match /reports/{reportId} {
      allow write: if isAdmin(); // Admin can seed and manage all reports
      // Any signed-in user can create a report document.
      allow create: if isSignedIn();
      // Access to reports is determined by involvement in the job/asset.
      allow read: if isSignedIn();
      allow update, delete: if isOwner(resource.data.inspectorId);
    }
    
    // All other collections that are either public or admin-only
    match /asset_types/{assetTypeId} { allow read: if true; allow write: if isAdmin(); }
    match /techniques/{techniqueId} { allow read: if true; allow write: if isAdmin(); }
    match /manufacturers/{manufacturerId} { allow read: if true; allow write: if isAdmin(); }
    match /equipment/{equipmentId} {
      allow write: if isAdmin(); // Admin can seed and manage all equipment
      allow read: if true;
      allow create: if (isSignedIn() && request.resource.data.providerId == userCompanyId(request.auth.uid));
      // Simplified update rule to avoid get() in batch writes
      allow update, delete: if (isSignedIn() && (userCompanyId(request.auth.uid) == resource.data.providerId));
      allow list: if true;
    }
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /plans/{planId} {
      allow read: if true; 
      allow write: if isAdmin();
    }
    match /defects/{defectId} { allow read, write: if isAdmin(); }
    match /subscriptions/{subscriptionId} { allow read, write: if isAdmin(); }
    match /roles_admin/{userId} { allow read, write: if isAdmin(); }
    match /payments/{paymentId} { allow read, write: if isAdmin(); }
    match /jobPayments/{paymentId} { allow read, write: if isAdmin(); }
    match /reviews/{reviewId} {
        // Allow public listing of reviews. The client query is responsible for filtering by 'Approved'.
        allow list: if true;
        // Allow getting a single document if it's approved, or if the user is signed in.
        allow get: if resource.data.status == 'Approved' || isSignedIn();
        allow create: if isSignedIn() || isAdmin();
        allow write: if isAdmin();
    }
    match /userAuditLogs/{logId} { allow read, write: if isAdmin(); }
    match /jobAuditLogs/{logId} { allow read, write: if isAdmin(); }
    match /billingAuditLogs/{logId} { allow read, write: if isAdmin(); }
  }
}
