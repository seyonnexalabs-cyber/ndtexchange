rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // WARNING: TEMPORARY DEBUGGING RULE - INSECURE
    // This rule allows anyone to read and write to any document.
    // It is a temporary measure to isolate the source of a persistent permission error.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
