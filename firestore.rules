
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Public Read-Only Collections
    // --------------------------------
    match /products/{productId} {
      // Allow public read access for catalogs and browsing.
      allow get, list: if true;
      // Allow write only by admins or the manufacturer who owns the product.
      // This rule now uses custom claims and request data, avoiding get() calls.
      allow write: if isAdmin() || (isManufacturer() && request.resource.data.manufacturerId == request.auth.token.companyId);
    }
    match /manufacturers/{manufacturerId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    match /techniques/{techniqueId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    match /asset_types/{assetTypeId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
     match /plans/{planId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    // --------------------------------
    // Helper Functions (Refactored to use Custom Claims)
    // --------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // UIDs for admin@ndtexchange.com and seyonnexalabs@gmail.com
    function isAdmin() {
      return isSignedIn() && (request.auth.uid == 'i947NWP5Hfb3Tpe5P6XcrjODRIJ2' || request.auth.uid == '8ulGMzDhV1VgocwqptGCpV6Dkkl1');
    }

    // Checks for a custom claim on the user's auth token. No get() call needed.
    function isManufacturer() {
      return isSignedIn() && request.auth.token.role == 'Manufacturer';
    }

    // Checks for a custom claim on the user's auth token. No get() call needed.
    function isJobParticipant(job) {
       return isSignedIn() && 
              (job.clientCompanyId == request.auth.token.companyId ||
              (job.providerId != null && job.providerId == request.auth.token.companyId));
    }


    // --------------------------------
    // Collection Rules (Refactored)
    // --------------------------------

    match /users/{userId} {
      allow write: if isAdmin(); // Admin can seed
      allow create: if isOwner(userId);
      allow get: if isSignedIn();
      allow update, delete: if isOwner(userId);
      allow list: if true; // WARNING: Overly permissive. In production, restrict to admins.

      match /notifications/{notificationId} {
        allow read, update, write: if isOwner(userId);
      }

      match /tasks/{taskId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /companies/{companyId} {
      allow write: if isAdmin(); // Admin can seed
      allow create: if (isSignedIn() && request.resource.data.contactEmail == request.auth.token.email);
      allow read, list: if true;
      allow update: if isAdmin();

      match /supportChats/{chatId} {
        allow read, write: if request.auth.token.companyId == companyId || isAdmin();

        match /supportMessages/{messageId} {
          allow read, write: if request.auth.token.companyId == companyId || isAdmin();
        }
      }
    }

    match /assets/{assetId} {
      allow write: if isAdmin(); // Admin can seed
      allow create: if (isSignedIn() && request.resource.data.companyId == request.auth.token.companyId);
      allow list: if isSignedIn();
      allow get, update, delete: if (isSignedIn() && (request.auth.token.companyId == resource.data.companyId || isAdmin()));

      match /inspections/{inspectionId} {
        // Create allowed if you are a member of the asset's company.
        // Reading the parent document's data is allowed in subcollection rules.
        allow create: if (isSignedIn() && get(parent).data.companyId == request.auth.token.companyId);
        allow get, list, update, delete: if (isSignedIn() && (isOwner(resource.data.inspectorId) || get(parent).data.companyId == request.auth.token.companyId));
      }
    }

    match /jobs/{jobId} {
      allow write: if isAdmin();
      allow create: if (isSignedIn() && (request.resource.data.clientId == request.auth.uid || request.resource.data.clientCompanyId == request.auth.token.companyId));
      allow list: if isSignedIn(); // Secured by client-side queries
      
      // GET and UPDATE rules now use request.auth.token instead of get()
      allow get, update: if (isSignedIn() && 
                             (request.auth.token.companyId == resource.data.clientCompanyId || 
                              request.auth.token.companyId == resource.data.providerId)) || isAdmin();

      allow delete: if (isSignedIn() && request.auth.token.companyId == resource.data.clientCompanyId) || isAdmin();

      match /bids/{bidId} {
        allow create: if (isSignedIn() && request.resource.data.inspectorId == request.auth.uid);
        // get() is okay here because it's on a specific document, not a list query.
        allow get, list: if (isSignedIn() && request.auth.token.companyId == get(/databases/$(database)/documents/jobs/$(jobId)).data.clientCompanyId) || isAdmin() || isOwner(resource.data.inspectorId);
        allow update: if (isSignedIn() && (isOwner(resource.data.inspectorId) || request.auth.token.companyId == get(/databases/$(database)/documents/jobs/$(jobId)).data.clientCompanyId));
        allow delete: if isOwner(resource.data.inspectorId);
      }

      match /messages/{messageId} {
        // get() is okay here for document-specific access, not list queries.
        allow read, create: if (isSignedIn() && isJobParticipant(get(/databases/$(database)/documents/jobs/$(jobId)).data)) || isAdmin();
      }
    }

    match /reports/{reportId} {
      allow write: if isAdmin();
      allow create: if isSignedIn();
      allow read, update, delete: if isSignedIn(); // Simplify for now, logic would be complex
    }

    match /equipment/{equipmentId} {
      allow read, list: if true;
      allow create: if (isSignedIn() && request.resource.data.providerId == request.auth.token.companyId);
      allow update, delete: if (isSignedIn() && resource.data.providerId == request.auth.token.companyId);
    }
    
    // Admin-only collections
    match /defects/{defectId} { allow read, write: if isAdmin(); }
    match /subscriptions/{subscriptionId} { allow read, write: if isAdmin(); }
    match /roles_admin/{userId} { allow read, write: if isAdmin(); }
    match /payments/{paymentId} { allow read, write: if isAdmin(); }
    match /jobPayments/{paymentId} { allow read, write: if isAdmin(); }
    match /userAuditLogs/{logId} { allow read, write: if isAdmin(); }
    match /jobAuditLogs/{logId} { allow read, write: if isAdmin(); }
    match /billingAuditLogs/{logId} { allow read, write: if isAdmin(); }

    match /reviews/{reviewId} {
        allow list: if resource.data.status == 'Approved';
        allow get: if resource.data.status == 'Approved' || isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isAdmin();
    }
  }
}
