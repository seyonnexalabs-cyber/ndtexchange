
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      // Check for the 'Admin' role in the user's own profile document.
      return getUserData().role == 'Admin';
    }
    
    // --- User Data ---
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      // Admins need to be able to list all users.
      allow list: if isAdmin();

      // User-owned sub-collections (notifications, tasks)
      match /{subcollection}/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
    
    // --- Business Logic Collections ---
    
    // Jobs and nested Bids/Messages
    match /jobs/{jobId} {
      allow get: if isSignedIn() && (
        isOwner(resource.data.userId) || 
        getUserData().companyId == resource.data.providerCompanyId ||
        isAdmin()
      );
      
      allow list: if isSignedIn();

      allow write: if (isSignedIn() && (
        isOwner(request.resource.data.userId) ||
        getUserData().companyId == request.resource.data.providerCompanyId
      )) || isAdmin();
      
      // Messages are only accessible by participants or admin
      match /messages/{messageId} {
        allow read, write: if (isSignedIn() && (
            isOwner(get(/databases/$(database)/documents/jobs/$(jobId)).data.userId) ||
            getUserData().companyId == get(/databases/$(database)/documents/jobs/$(jobId)).data.providerCompanyId
        )) || isAdmin();
      }
    }

    // Bids (top-level collection)
    match /bids/{bidId} {
        // Creation: Inspector creating their own bid.
        allow create: if (isSignedIn() && request.auth.uid == request.resource.data.inspectorId) || isAdmin();
        
        // Reading: Inspector reads their own bids, client reads bids on their jobs.
        allow get: if (isSignedIn() && (request.auth.uid == resource.data.inspectorId || request.auth.uid == resource.data.userId)) || isAdmin();
        
        // Listing: Securely allow inspectors to list only their own bids.
        allow list: if (isSignedIn() && request.query.where[0] == 'inspectorId' && request.query.where[2] == request.auth.uid) || isAdmin();

        // Updating: Client can accept/reject, inspector can withdraw (by updating status).
        allow update: if (isSignedIn() && (request.auth.uid == resource.data.inspectorId || request.auth.uid == resource.data.userId)) || isAdmin();
    }
    
    // Assets and nested Inspections
    match /assets/{assetId} {
      allow read, write: if (isSignedIn() && getUserData().companyId == resource.data.companyId) || isAdmin();

      match /inspections/{inspectionId} {
        allow read, write: if (isSignedIn() && getUserData().companyId == get(/databases/$(database)/documents/assets/$(assetId)).data.companyId) || isAdmin();
      }
    }

    // Top-level Public/Semi-public data
    match /companies/{companyId} { 
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /techniques/{techniqueId} { 
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /manufacturers/{manufacturerId} { 
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /products/{productId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow write: if (isSignedIn() && (request.resource.data.clientId == request.auth.uid || request.resource.data.providerId == getUserData().companyId)) || isAdmin();
    }
    match /plans/{planId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Admin-only Data ---
    // These collections are only accessible by administrators.
    match /jobPayments/{doc=**} { allow read, write: if isAdmin(); }
    match /payments/{doc=**} { allow read, write: if isAdmin(); }
    match /subscriptions/{doc=**} { allow read, write: if isAdmin(); }
    match /billingAuditLogs/{doc=**} { allow read, write: if isAdmin(); }
    match /jobAuditLogs/{doc=**} { allow read, write: if isAdmin(); }
    match /userAuditLogs/{doc=**} { allow read, write: if isAdmin(); }
    match /reports/{doc=**} { allow read, write: if isAdmin(); }
    
  }
}
