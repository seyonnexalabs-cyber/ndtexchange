

{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the application (client, inspector, admin).",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the User entity." },
        "companyId": { "type": "string", "description": "The ID of the company the user belongs to." },
        "company": { "type": "string", "description": "The name of the company the user belongs to." },
        "name": { "type": "string", "description": "The user's full name." },
        "email": { "type": "string", "description": "The user's email address.", "format": "email" },
        "role": { "type": "string", "description": "The user's role (e.g., Client, Inspector, Auditor, Admin, Manufacturer)." },
        "certifications": { "type": "array", "description": "List of certifications held by the user (especially for inspectors).", "items": { "type": "string" } },
        "skills": { "type": "array", "description": "List of skills possessed by the user (especially for inspectors).", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "modifiedAt": { "type": "string", "format": "date-time" },
        "modifiedBy": { "type": "string" }
      },
      "required": ["id", "companyId", "company", "name", "email", "role"]
    },
    "Company": {
      "title": "Company",
      "type": "object",
      "description": "Represents a company, which can be a Client, Provider, or Auditor.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Client", "Provider", "Auditor"] },
        "address": { "type": "object", "properties": { "street": { "type": "string" }, "city": { "type": "string" }, "state": { "type": "string" }, "postalCode": { "type": "string" }, "country": { "type": "string" } } },
        "contactPerson": { "type": "string" },
        "contactEmail": { "type": "string", "format": "email" }
      },
      "required": ["id", "name", "type"]
    },
    "Asset": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Asset",
      "type": "object",
      "description": "Represents an asset, such as equipment, structure, or component.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the Asset entity." },
        "companyId": { "type": "string", "description": "The ID of the company that owns this asset." },
        "assetTypeId": { "type": "string", "description": "Reference to the AssetType entity." },
        "name": { "type": "string", "description": "The name of the asset." },
        "description": { "type": "string", "description": "A detailed description of the asset." },
        "location": { "type": "string", "description": "The primary site where the asset is typically located." },
        "isMovable": { "type": "boolean", "description": "Indicates if the asset is movable or fixed." },
        "qrCode": { "type": "string", "description": "The QR code associated with the asset for scanning." },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "modifiedAt": { "type": "string", "format": "date-time" },
        "modifiedBy": { "type": "string" }
      },
      "required": ["id", "companyId", "name", "isMovable"]
    },
    "Equipment": {
      "title": "Equipment",
      "type": "object",
      "description": "A piece of NDT equipment owned by a service provider.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "providerId": { "type": "string" },
        "type": { "type": "string", "enum": ["Instrument", "Probe", "Source", "Sensor", "Calibration Standard", "Accessory", "Visual Aid"] },
        "techniques": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["Available", "In Use", "Calibration Due", "Out of Service", "Under Service"] },
        "nextCalibration": { "type": "string", "format": "date" }
      },
      "required": ["id", "name", "providerId", "type", "status", "nextCalibration"]
    },
    "Inspection": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Inspection",
      "type": "object",
      "description": "Represents an inspection event performed on an asset.",
      "properties": {
        "id": { "type": "string" },
        "assetId": { "type": "string" },
        "jobId": { "type": "string" },
        "inspectorId": { "type": "string" },
        "status": { "type": "string", "enum": ["scheduled", "done", "failed"] },
        "results": { "type": "object" },
        "attachments": { "type": "array", "items": { "type": "object" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "modifiedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "assetId", "jobId", "inspectorId", "status"]
    },
    "Job": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Job",
      "type": "object",
      "description": "Represents a job request created by a client.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "clientCompanyId": { "type": "string" },
        "providerCompanyId": { "type": "string" },
        "auditorCompanyId": { "type": ["string", "null"] },
        "requestedByUid": { "type": ["string", "null"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "location": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "requested", "quoted", "scheduled", "in_progress", "completed", "cancelled"] },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "technicianIds": { "type": "array", "items": { "type": "string" } },
        "internalNotes": { "type": "string" },
        "attachments": { "type": "array", "items": { "type": "object" } },
        "temaDesignIds": { "type": "array", "items": { "type": "string" }, "description": "A list of IDs of TEMA designs attached to this job." },
        "createdAt": { "type": "string", "format": "date-time" },
        "modifiedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title"]
    },
    "Message": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Message",
      "type": "object",
      "description": "Represents a message sent between users within a job.",
      "properties": {
        "id": { "type": "string" },
        "jobId": { "type": "string" },
        "senderId": { "type": "string" },
        "body": { "type": "string" },
        "attachments": { "type": "array", "items": { "type": "object" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "modifiedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "jobId", "senderId", "body"]
    },
    "SupportThread": {
      "title": "Support Thread",
      "type": "object",
      "description": "Represents a single support conversation thread.",
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string" },
        "companyName": { "type": "string" },
        "subject": { "type": "string" },
        "status": { "type": "string", "enum": ["Open", "Closed"] },
        "lastMessage": { "type": "string" },
        "lastMessageTimestamp": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["id", "companyId", "subject", "status"]
    },
    "SupportMessage": {
      "title": "Support Message",
      "type": "object",
      "description": "A single message within a support thread.",
      "properties": {
        "id": { "type": "string" },
        "supportChatId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" },
        "text": { "type": "string" }
      },
      "required": ["id", "supportChatId", "senderId", "senderName", "timestamp", "text"]
    },
    "Bid": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Bid",
      "type": "object",
      "description": "Represents a bid submitted by an inspector for a job.",
      "properties": {
        "id": { "type": "string" },
        "jobId": { "type": "string" },
        "inspectorId": { "type": "string" },
        "userId": { "type": "string" },
        "providerCompanyId": { "type": "string" },
        "clientCompanyId": { "type": "string", "description": "The ID of the client company for the job." },
        "amount": { "type": "number" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["Submitted", "Shortlisted", "Awarded", "Rejected", "Withdrawn", "Not Selected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "jobId", "inspectorId", "userId", "providerCompanyId", "amount", "clientCompanyId"]
    },
    "Review": {
      "title": "Review",
      "type": "object",
      "description": "A review for a service provider.",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "providerCompanyId": { "type": "string" },
        "rating": { "type": "number", "minimum": 1, "maximum": 5 },
        "text": { "type": "string" },
        "providerReply": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "clientId", "providerCompanyId", "rating", "text"]
    },
    "Task": {
        "title": "Task",
        "type": "object",
        "description": "A user-specific to-do item.",
        "properties": {
            "id": { "type": "string" },
            "userId": { "type": "string" },
            "title": { "type": "string" },
            "status": { "type": "string", "enum": ["todo", "in progress", "done", "canceled"] },
            "priority": { "type": "string", "enum": ["low", "medium", "high"] },
            "label": { "type": "string" }
        },
        "required": ["id", "userId", "title", "status", "priority", "label"]
    },
    "UserAuditLog": {
        "title": "User Audit Log",
        "type": "object",
        "description": "Logs user-related administrative actions.",
        "properties": {
            "id": { "type": "string" },
            "timestamp": { "type": "string", "format": "date-time" },
            "actorName": { "type": "string" },
            "action": { "type": "string" },
            "targetUserName": { "type": "string" }
        }
    },
    "JobAuditLog": {
        "title": "Job Audit Log",
        "type": "object",
        "description": "Logs job-related activities.",
        "properties": {
            "id": { "type": "string" },
            "timestamp": { "type": "string", "format": "date-time" },
            "jobId": { "type": "string" },
            "actorName": { "type": "string" },
            "action": { "type": "string" }
        }
    },
    "BillingAuditLog": {
        "title": "Billing Audit Log",
        "type": "object",
        "description": "Logs billing and subscription events.",
        "properties": {
            "id": { "type": "string" },
            "timestamp": { "type": "string", "format": "date-time" },
            "companyName": { "type": "string" },
            "action": { "type": "string" }
        }
    },
    "Payment": {
        "title": "Payment",
        "type": "object",
        "description": "Represents a subscription payment.",
        "properties": {
            "id": { "type": "string" },
            "subscriptionId": { "type": "string" },
            "amount": { "type": "number" },
            "date": { "type": "string", "format": "date-time" },
            "status": { "type": "string" }
        }
    },
    "Subscription": {
        "title": "Subscription",
        "type": "object",
        "description": "Represents a company's subscription plan.",
        "properties": {
            "id": { "type": "string" },
            "companyId": { "type": "string" },
            "plan": { "type": "string" },
            "status": { "type": "string" },
            "startDate": { "type": "string", "format": "date-time" }
        }
    },
    "JobPayment": {
        "title": "Job Payment",
        "type": "object",
        "description": "Represents a payment for a specific job.",
        "properties": {
            "id": { "type": "string" },
            "jobId": { "type": "string" },
            "amount": { "type": "number" },
            "payer": { "type": "string" },
            "payee": { "type": "string" },
            "status": { "type": "string" }
        }
    },
    "NDTTechnique": {
        "title": "NDT Technique",
        "type": "object",
        "description": "A non-destructive testing technique.",
        "properties": {
            "id": { "type": "string" },
            "acronym": { "type": "string" },
            "title": { "type": "string" },
            "description": { "type": "string" },
            "isHighlighted": { "type": "boolean" },
            "imageId": { "type": "string" }
        },
        "required": ["id", "acronym", "title", "description"]
    },
    "Manufacturer": {
        "title": "Manufacturer",
        "type": "object",
        "description": "An OEM of NDT equipment.",
        "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" },
            "url": { "type": "string", "format": "uri" },
            "description": { "type": "string" },
            "logoUrl": { "type": "string", "format": "uri" },
            "techniqueIds": { "type": "array", "items": { "type": "string" } },
            "contactEmail": { "type": "string", "format": "email" }
        },
        "required": ["id", "name", "url", "techniqueIds"]
    },
    "Product": {
        "title": "Product",
        "type": "object",
        "description": "An NDT product or piece of equipment.",
        "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" },
            "manufacturerId": { "type": "string" },
            "manufacturerName": { "type": "string" },
            "type": { "type": "string", "enum": ["Instrument", "Probe", "Source", "Sensor", "Calibration Standard", "Accessory", "Visual Aid"] },
            "techniques": { "type": "array", "items": { "type": "string" } },
            "description": { "type": "string" },
            "imageUrls": { "type": "array", "items": { "type": "string", "format": "uri" } },
            "isAwardWinning": { "type": "boolean" },
            "awards": { 
                "type": "array", 
                "items": { 
                    "type": "object",
                    "properties": {
                        "name": { "type": "string" },
                        "year": { "type": "number" },
                        "imageUrl": { "type": "string", "format": "uri" }
                    }
                } 
            },
            "specifications": {
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "name": { "type": "string" },
                        "value": { "type": "string" }
                    }
                }
            },
            "certifications": {
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "name": { "type": "string" },
                        "authority": { "type": "string" },
                        "logoUrl": { "type": "string", "format": "uri" }
                    }
                }
            }
        },
        "required": ["id", "name", "manufacturerId", "manufacturerName", "type", "techniques"]
    },
    "Plan": {
        "title": "Subscription Plan",
        "type": "object",
        "description": "A subscription plan for the platform.",
        "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" },
            "audience": { "type": "string", "enum": ["Client", "Provider", "Auditor"] },
            "price": {
                "type": "object",
                "properties": {
                    "monthlyUSD": { "type": "number" },
                    "yearlyUSD": { "type": "number" }
                }
            },
            "description": { "type": "string" },
            "userLimit": { "type": ["number", "string"] },
            "dataLimitGB": { "type": ["number", "string"] },
            "assetLimit": { "type": ["number", "string"] },
            "biddingLimit": { "type": ["number", "string"] },
            "equipmentLimit": { "type": ["number", "string"] },
            "marketplaceAccess": { "type": "boolean" },
            "reportingLevel": { "type": "string", "enum": ["Basic", "Advanced"] },
            "apiAccess": { "type": "boolean" },
            "customBranding": { "type": "boolean" },
            "isPublic": { "type": "boolean" },
            "isActive": { "type": "boolean" },
            "isFeatured": { "type": "boolean" },
            "isPopular": { "type": "boolean" },
            "features": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["id", "name", "audience", "price"]
    },
    "Event": {
      "title": "Event",
      "type": "object",
      "description": "An industry event, conference, or exhibition.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "location": { "type": "string" },
        "region": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "imageHint": { "type": "string" },
        "url": { "type": "string", "format": "uri" }
      },
      "required": ["id", "title", "date", "location", "region", "url", "imageUrl"]
    },
    "TemaDesign": {
        "title": "TEMA Design",
        "type": "object",
        "description": "Represents a saved TEMA tubesheet layout design.",
        "properties": {
            "id": { "type": "string" },
            "userId": { "type": "string" },
            "name": { "type": "string" },
            "description": { "type": "string" },
            "config": { "type": "object" },
            "tubes": { "type": "array", "items": { "type": "object" } },
            "createdAt": { "type": "string", "format": "date-time" },
            "modifiedAt": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "userId", "name", "config", "tubes"]
    },
    "TankDesign": {
        "title": "Tank Design",
        "type": "object",
        "description": "Represents a saved Storage Tank inspection layout and data.",
        "properties": {
            "id": { "type": "string" },
            "userId": { "type": "string" },
            "name": { "type": "string" },
            "description": { "type": "string" },
            "config": {
                "type": "object",
                "properties": {
                    "diameter": { "type": "number", "description": "Tank diameter in feet" },
                    "shellCourses": { "type": "number", "description": "Number of shell courses" },
                    "floorPlates": { "type": "number", "description": "Number of floor plates" }
                }
            },
            "floorScans": {
                "type": "array",
                "description": "Data points for the floor scan map.",
                "items": {
                    "type": "object",
                    "properties": {
                        "plate": { "type": "number" },
                        "x": { "type": "number" },
                        "y": { "type": "number" },
                        "thickness": { "type": "number" }
                    }
                }
            },
            "shellReadings": {
                "type": "array",
                "description": "Thickness readings for each shell course.",
                "items": {
                    "type": "object",
                    "properties": {
                        "course": { "type": "number" },
                        "readings": {
                            "type": "array",
                            "items": { "type": "number" }
                        }
                    }
                }
            },
            "annularReadings": {
                "type": "array",
                "description": "Readings for the annular plate ring.",
                "items": {
                    "type": "object",
                    "properties": {
                        "position": { "type": "string", "description": "e.g., 3 o'clock" },
                        "thickness": { "type": "number" }
                    }
                }
            },
            "createdAt": { "type": "string", "format": "date-time" },
            "modifiedAt": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "userId", "name", "config"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      { "path": "/users/{uid}", "definition": { "entityName": "User", "schema": { "$ref": "#/entities/User" }, "description": "Stores user profiles." } },
      { "path": "/tasks/{taskId}", "definition": { "entityName": "Task", "schema": { "$ref": "#/entities/Task" }, "description": "User-specific tasks." } },
      { "path": "/companies/{companyId}", "definition": { "entityName": "Company", "schema": { "$ref": "#/entities/Company" }, "description": "Top-level collection for all companies." } },
      { "path": "/assets/{assetId}", "definition": { "entityName": "Asset", "schema": { "$ref": "#/entities/Asset" }, "description": "Assets owned by a company." } },
      { "path": "/inspections/{inspectionId}", "definition": { "entityName": "Inspection", "schema": { "$ref": "#/entities/Inspection" }, "description": "Inspections performed on assets." } },
      { "path": "/jobs/{jobId}", "definition": { "entityName": "Job", "schema": { "$ref": "#/entities/Job" }, "description": "Job requests from clients." } },
      { "path": "/messages/{messageId}", "definition": { "entityName": "Message", "schema": { "$ref": "#/entities/Message" }, "description": "Messages within a job." } },
      { "path": "/bids/{bidId}", "definition": { "entityName": "Bid", "schema": { "$ref": "#/entities/Bid" }, "description": "Bids on jobs." } },
      { "path": "/supportChats/{supportChatId}", "definition": { "entityName": "SupportThread", "schema": { "$ref": "#/entities/SupportThread" }, "description": "Support conversation threads." } },
      { "path": "/supportMessages/{messageId}", "definition": { "entityName": "SupportMessage", "schema": { "$ref": "#/entities/SupportMessage" }, "description": "Individual messages within a support thread." } },
      { "path": "/equipment/{equipmentId}", "definition": { "entityName": "Equipment", "schema": { "$ref": "#/entities/Equipment" }, "description": "Top-level collection for all NDT equipment." } },
      { "path": "/userAuditLogs/{logId}", "definition": { "entityName": "UserAuditLog", "schema": { "$ref": "#/entities/UserAuditLog" }, "description": "Audit logs for user management actions." } },
      { "path": "/jobAuditLogs/{logId}", "definition": { "entityName": "JobAuditLog", "schema": { "$ref": "#/entities/JobAuditLog" }, "description": "Audit logs for job-related activities." } },
      { "path": "/billingAuditLogs/{logId}", "definition": { "entityName": "BillingAuditLog", "schema": { "$ref": "#/entities/BillingAuditLog" }, "description": "Audit logs for billing and subscription events." } },
      { "path": "/payments/{paymentId}", "definition": { "entityName": "Payment", "schema": { "$ref": "#/entities/Payment" }, "description": "Records of subscription payments." } },
      { "path": "/subscriptions/{subId}", "definition": { "entityName": "Subscription", "schema": { "$ref": "#/entities/Subscription" }, "description": "Company subscription plans." } },
      { "path": "/jobPayments/{jobPaymentId}", "definition": { "entityName": "JobPayment", "schema": { "$ref": "#/entities/JobPayment" }, "description": "Records of payments for specific jobs." } },
      { "path": "/reviews/{reviewId}", "definition": { "entityName": "Review", "schema": { "$ref": "#/entities/Review" }, "description": "All product and provider reviews." } },
      { "path": "/techniques/{techId}", "definition": { "entityName": "NDTTechnique", "schema": { "$ref": "#/entities/NDTTechnique" }, "description": "Public directory of NDT techniques." } },
      { "path": "/manufacturers/{manuId}", "definition": { "entityName": "Manufacturer", "schema": { "$ref": "#/entities/Manufacturer" }, "description": "Public directory of NDT equipment manufacturers." } },
      { "path": "/products/{prodId}", "definition": { "entityName": "Product", "schema": { "$ref": "#/entities/Product" }, "description": "Public directory of NDT products." } },
      { "path": "/plans/{planId}", "definition": { "entityName": "Plan", "schema": { "$ref": "#/entities/Plan" }, "description": "Public directory of subscription plans." } },
      { "path": "/events/{eventId}", "definition": { "entityName": "Event", "schema": { "$ref": "#/entities/Event" }, "description": "Public directory of industry events." } },
