
rules_version = '2';
service cloud.firestore {

  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isAdmin() {
      // In a real app, this would check a custom claim or a roles collection.
      // For this demo, we are hardcoding the admin UIDs.
      return request.auth.uid in ['i947NWP5Hfb3Tpe5P6XcrjODRIJ2', '8ulGMzDhV1VgocwqptGCpV6Dkkl1'];
    }
    
    function isManufacturerOwner(manufacturerId) {
      // This function uses get() and cannot be used in rules evaluated during batch writes.
      // It's intended for UI operations by a logged-in manufacturer.
      let userCompanyId = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId;
      return userCompanyId == manufacturerId;
    }

    // PUBLIC COLLECTIONS
    match /products/{productId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    match /manufacturers/{manufacturerId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    match /techniques/{techniqueId} {
        allow get, list: if true;
        allow write: if isAdmin();
    }
    
    match /asset_types/{assetTypeId} {
        allow get, list: if true;
        allow write: if isAdmin();
    }

    // USER-SPECIFIC DATA
    match /users/{userId} {
      allow read, update: if isOwner(userId) || isAdmin();
      // Allow user to create own profile, or admin to create any profile for seeding.
      allow create: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // JOB-RELATED COLLECTIONS
    match /jobs/{jobId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Simplified for now
    }
    
    // This single block now correctly handles all bid-related security.
    match /{path=**}/bids/{bidId} {
        // ALLOWS an inspector to query for their own bids across all jobs.
        // The client-side query must include `where('inspectorId', '==', request.auth.uid)`.
        allow list: if request.auth.uid == resource.data.inspectorId;

        // ALLOWS the job owner OR the bid owner to get a single bid document.
        allow get: if request.auth.uid == resource.data.userId || request.auth.uid == resource.data.inspectorId;

        // ALLOWS an inspector to create a bid for themselves.
        allow create: if request.auth.uid == request.resource.data.inspectorId;

        // ALLOWS the client (job owner) to update status, or the inspector to update their own submitted bid.
        allow update: if request.auth.uid == resource.data.userId || (request.auth.uid == resource.data.inspectorId && resource.data.status == 'Submitted');
    }


    match /jobs/{jobId}/messages/{messageId} {
      allow read, write: if isSignedIn(); // Simplified
    }

    // COMPANY DATA
    match /companies/{companyId} {
        allow read, list: if isSignedIn();
        allow write: if isAdmin();
    }
    
    match /companies/{companyId}/{subcollection=**} {
        allow read, write: if isAdmin();
    }
    
    // OTHER COLLECTIONS
     match /assets/{assetId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Simplified
    }
    
     match /assets/{assetId}/{subcollection=**} {
       allow read, write: if isSignedIn(); // Simplified
    }
    
    match /equipment/{equipmentId} {
      allow read, write: if isAdmin();
    }

    match /reports/{reportId} {
        allow read, write: if isSignedIn(); // Simplified
    }

    match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update: if isAdmin();
    }
    
    // ADMIN-ONLY COLLECTIONS
    match /jobPayments/{paymentId} {
        allow read, write: if isAdmin();
    }
    
     match /payments/{paymentId} {
        allow read, write: if isAdmin();
    }

     match /subscriptions/{subscriptionId} {
        allow read, write: if isAdmin();
    }
    
     match /plans/{planId} {
        allow read, write: if isAdmin();
    }
    
     match /userAuditLogs/{logId} {
        allow read, write: if isAdmin();
    }
    
     match /jobAuditLogs/{logId} {
        allow read, write: if isAdmin();
    }

     match /billingAuditLogs/{logId} {
        allow read, write: if isAdmin();
    }
  }
}
