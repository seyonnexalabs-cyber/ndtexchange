
rules_version = '2';
service cloud.firestore {

  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isAdmin() {
      // In a real app, this would check a custom claim or a roles collection.
      // For this demo, we are hardcoding the admin UIDs.
      return request.auth.uid in ['i947NWP5Hfb3Tpe5P6XcrjODRIJ2', '8ulGMzDhV1VgocwqptGCpV6Dkkl1'];
    }
    
    function isManufacturerOwner(manufacturerId) {
      let userCompanyId = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId;
      return userCompanyId == manufacturerId;
    }

    // PUBLIC COLLECTIONS
    match /products/{productId} {
      // Allow ANYONE to read any product data. This is the most permissive rule possible
      // and should allow all queries, filtered or not.
      allow read: if true;
      
      // Write permissions are still restricted to the product's manufacturer owner.
      allow create: if isSignedIn() && isManufacturerOwner(request.resource.data.manufacturerId);
      allow update: if isSignedIn() && isManufacturerOwner(resource.data.manufacturerId);
      allow delete: if isSignedIn() && isManufacturerOwner(resource.data.manufacturerId);
    }
    
    match /manufacturers/{manufacturerId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    match /techniques/{techniqueId} {
        allow get, list: if true;
        allow write: if isAdmin();
    }
    
    match /asset_types/{assetTypeId} {
        allow get, list: if true;
        allow write: if isAdmin();
    }

    // USER-SPECIFIC DATA
    match /users/{userId} {
      allow read, update: if isOwner(userId) || isAdmin();
      allow create: if request.auth.uid == userId;
    }

    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // JOB-RELATED COLLECTIONS
    match /jobs/{jobId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Simplified for now, should be more granular
    }

    match /jobs/{jobId}/bids/{bidId} {
      // This combined read rule allows an inspector to read their own bids,
      // a client to read bids on their job, and an admin to read any bid.
      // It relies on clientId being present on the bid document, which is now added on creation.
      allow read: if isSignedIn() && 
                   (request.auth.uid == resource.data.inspectorId || 
                    request.auth.uid == resource.data.clientId || 
                    isAdmin());

      // Only an inspector can create a bid on their own behalf.
      allow create: if isSignedIn() && request.resource.data.inspectorId == request.auth.uid;
      
      // Client can update bid status, inspector can withdraw their bid.
      // The get() call is removed here to prevent conflicts with collection group queries.
      allow update: if isSignedIn() && 
                     (request.auth.uid == resource.data.clientId || 
                      resource.data.inspectorId == request.auth.uid || 
                      isAdmin());
    }

    match /jobs/{jobId}/messages/{messageId} {
      allow read, write: if isSignedIn(); // Simplified
    }

    // COMPANY DATA
    match /companies/{companyId} {
        allow read, list: if isSignedIn();
        allow write: if isAdmin();
    }
    
    match /companies/{companyId}/{subcollection=**} {
        allow read, write: if isAdmin();
    }
    
    // OTHER COLLECTIONS
     match /assets/{assetId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Simplified
    }
    
     match /assets/{assetId}/{subcollection=**} {
       allow read, write: if isSignedIn(); // Simplified
    }

    match /reports/{reportId} {
        allow read, write: if isSignedIn(); // Simplified
    }

    match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update: if isAdmin();
    }

    match /jobPayments/{paymentId} {
        allow read, write: if isAdmin();
    }
    
     match /payments/{paymentId} {
        allow read, write: if isAdmin();
    }
    
     match /userAuditLogs/{logId} {
        allow read: if isAdmin();
    }
    
     match /jobAuditLogs/{logId} {
        allow read: if isAdmin();
    }

     match /billingAuditLogs/{logId} {
        allow read: if isAdmin();
    }
  }
}
