
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // This is the definitive way to check for admin.
    // UIDs are for admin@ndtexchange.com and seyonnexalabs@gmail.com
    function isAdmin() {
      return isSignedIn() && (request.auth.uid == 'i947NWP5Hfb3Tpe5P6XcrjODRIJ2' || request.auth.uid == '8ulGMzDhV1VgocwqptGCpV6Dkkl1');
    }

    function getUserCompanyId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId;
    }

    // --------------------------------
    // Collection Rules
    // --------------------------------

    match /users/{userId} {
      allow create: if isOwner(userId) || isAdmin();
      allow get: if isSignedIn();
      allow update, delete: if isAdmin() || isOwner(userId);
      allow list: if isAdmin();

      // FCM tokens can only be managed by the owner
      match /fcmTokens/{token} {
        allow read, write: if isOwner(userId);
      }

      // Notifications can only be read and updated by the owner
      match /notifications/{notificationId} {
        allow read, update: if isOwner(userId);
        // Only allow admin to create/delete notifications, not the user client-side
        allow create, delete: if isAdmin();
      }
    }

    match /companies/{companyId} {
      // Admins or the initial company contact can create a company document.
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.contactEmail == request.auth.token.email);
      // All company documents are publicly readable.
      allow read: if true;
      // Only admins can modify company data.
      allow write: if isAdmin();

      match /supportChats/{chatId} {
        // Only members of the company or admins can access support chats.
        allow read, write: if isAdmin() || getUserCompanyId() == companyId;
        
        match /supportMessages/{messageId} {
          allow read, write: if isAdmin() || getUserCompanyId() == companyId;
        }
      }
    }
    
    match /assets/{assetId} {
      // A user can create an asset for their own company, or an admin can create any asset.
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.companyId == getUserCompanyId());
      // For list queries, any signed-in user can perform them. The read rule provides document-level security.
      allow list: if isSignedIn();
      // You can only read/update/delete an asset if you're an admin or part of the asset's company.
      allow read, update, delete: if isAdmin() || (isSignedIn() && resource.data.companyId == getUserCompanyId());
      
      match /inspections/{inspectionId} {
        // Creating an inspection is allowed if you are an admin or a member of the asset's company.
        allow create: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/assets/$(assetId)).data.companyId == getUserCompanyId());
        // You can read an inspection if you are the inspector or a member of the asset's owning company.
        allow read: if isAdmin() || isOwner(resource.data.inspectorId) || get(/databases/$(database)/documents/assets/$(assetId)).data.companyId == getUserCompanyId();
        // Only the assigned inspector or an admin can update/delete.
        allow update, delete: if isAdmin() || isOwner(resource.data.inspectorId);
      }
    }

    match /jobs/{jobId} {
      // A signed-in user can create a job if they are the client, or an admin can.
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.clientId == request.auth.uid);
      // All jobs are publicly readable.
      allow read: if true;
      // Only the client, the awarded provider, or an admin can update a job.
      allow update: if isAdmin() || (isSignedIn() && (getUserCompanyId() == resource.data.clientCompanyId || getUserCompanyId() == resource.data.awardedProviderId));
      // Only the client or an admin can delete a job.
      allow delete: if isAdmin() || (isSignedIn() && getUserCompanyId() == resource.data.clientCompanyId);

      match /bids/{bidId} {
        // An inspector can create a bid for their own user ID, or an admin can.
        allow create: if isAdmin() || (isSignedIn() && request.resource.data.inspectorId == request.auth.uid);
        // The job client, the bidding inspector, or an admin can read bids.
        allow read: if isAdmin() || isOwner(resource.data.inspectorId) || getUserCompanyId() == get(/databases/$(database)/documents/jobs/$(jobId)).data.clientCompanyId;
        // Only the bidding inspector or an admin can update/delete.
        allow update, delete: if isAdmin() || isOwner(resource.data.inspectorId);
      }
      
      match /messages/{messageId} {
        // Admin can write anything (for seeding).
        allow write: if isAdmin();
        // Participants of the job can read messages and create new ones.
        allow read, create: if (isSignedIn() && (
            getUserCompanyId() == get(/databases/$(database)/documents/jobs/$(jobId)).data.clientCompanyId ||
            getUserCompanyId() == get(/databases/$(database)/documents/jobs/$(jobId)).data.awardedProviderId
          ));
      }
    }

    match /reports/{reportId} {
      // Any signed-in user can create a report document, or an admin can.
      allow create: if isSignedIn() || isAdmin();
      // Access to reports is determined by involvement in the job/asset.
      allow read: if isSignedIn();
      allow update, delete: if isAdmin() || isOwner(resource.data.inspectorId);
    }
    
    // All other collections that are either public or admin-only
    match /asset_types/{assetTypeId} { allow read: if true; allow write: if isAdmin(); }
    match /techniques/{techniqueId} { allow read: if true; allow write: if isAdmin(); }
    match /manufacturers/{manufacturerId} { allow read: if true; allow write: if isAdmin(); }
    match /equipment/{equipmentId} { allow read: if true; allow write: if isAdmin(); }
    match /defects/{defectId} { allow read, write: if isAdmin(); }
    match /subscriptions/{subscriptionId} { allow read, write: if isAdmin(); }
    match /roles_admin/{userId} { allow read, write: if isAdmin(); }
    match /payments/{paymentId} { allow read, write: if isAdmin(); }
    match /jobPayments/{paymentId} { allow read, write: if isAdmin(); }
    match /reviews/{reviewId} { allow read: if true; allow create: if isSignedIn() || isAdmin(); allow write: if isAdmin(); }
    match /userAuditLogs/{logId} { allow read, write: if isAdmin(); }
    match /jobAuditLogs/{logId} { allow read, write: if isAdmin(); }
    match /billingAuditLogs/{logId} { allow read, write: if isAdmin(); }
  }
}
