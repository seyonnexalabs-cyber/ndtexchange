rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -------- Helpers --------
    function authed() {
      return request.auth != null;
    }

    function isPlatformAdmin() {
      return authed() && request.auth.uid in ['i947NWP5Hfb3Tpe5P6XcrjODRIJ2', '8ulGMzDhV1VgocwqptGCpV6Dkkl1'];
    }
    
    // TEMPORARILY SIMPLIFIED FOR DEBUGGING AND DEMO PURPOSES
    // NOT FOR PRODUCTION
    match /{document=**} {
      allow read, write: if authed();
    }
  }
}
