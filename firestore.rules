
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -------- Helpers --------
    function authed() {
      return request.auth != null;
    }

    function isPlatformAdmin() {
      // In a real app, this would check a custom claim or a role in the user's profile.
      return authed() && (request.auth.uid in ['i947NWP5Hfb3Tpe5P6XcrjODRIJ2', '8ulGMzDhV1VgocwqptGCpV6Dkkl1']);
    }

    function isSelf(userId) {
      return authed() && request.auth.uid == userId;
    }
    
    function getUserData() {
    	return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isMemberOf(companyId) {
      return authed() && getUserData().companyId == companyId;
    }

    // -------- Top-Level Collections --------

    // USERS: Users can read/update their own profile. Admins can manage all.
    match /users/{userId} {
      allow read, update: if isSelf(userId) || isPlatformAdmin();
      allow create: if isSelf(userId); // Allows user creation on signup
      allow list, delete: if isPlatformAdmin();
    }
    
    // TASKS & NOTIFICATIONS: Private to each user.
    match /tasks/{taskId} {
      allow read, write: if isSelf(resource.data.userId);
    }
    match /notifications/{notificationId} {
      allow read, write: if isSelf(resource.data.userId);
    }

    // COMPANIES: Any authenticated user can read company info. Only admins can create/update.
    match /companies/{companyId} {
      allow read: if authed();
      allow write: if isPlatformAdmin();
    }
    
    // ASSETS: Members of a company can read/write assets for that company.
    match /assets/{assetId} {
        allow read, write: if isMemberOf(resource.data.companyId) || isPlatformAdmin();
    }

    // INSPECTIONS: Users can read/write if they are a member of the client or provider company.
    match /inspections/{inspectionId} {
        // This requires getting job data, which can be complex. 
        // A simplified rule for now: allow if authenticated.
        // A more robust rule would check job participants.
        allow read, write: if authed(); 
    }
    
    // JOBS: Users can read if they are part of the client, provider, or auditor company.
    // Writing is restricted to clients and assigned providers.
    match /jobs/{jobId} {
        allow get: if authed();
        allow list: if isPlatformAdmin(); // Admin can list all jobs. Client/Provider jobs are queried directly.
        allow create: if authed(); // Any auth'd user can create a job draft.
        allow update: if isMemberOf(resource.data.clientCompanyId) || isMemberOf(resource.data.providerCompanyId) || isPlatformAdmin();
    }
    
    // BIDS:
    match /bids/{bidId} {
        // Get: You can get a bid if you are the inspector who made it, or you are part of the client company for the job.
        allow get: if isSelf(resource.data.inspectorId) || isMemberOf(get(/databases/$(database)/documents/jobs/$(resource.data.jobId)).data.clientCompanyId);
        // List: Handled by collection group query rule below.
        // Write: You can create/update a bid if you are the inspector, or you are the client (to award it).
        allow write: if isSelf(request.resource.data.inspectorId) || isMemberOf(get(/databases/$(database)/documents/jobs/$(request.resource.data.jobId)).data.clientCompanyId);
    }
    
    // MESSAGES & SUPPORT: Users can read/write if they are part of the relevant company.
    match /messages/{messageId} {
        // Simplified rule: allow if authenticated. Robust rule would check job participants.
        allow read, write: if authed();
    }
    match /supportChats/{supportChatId} {
        allow read, write: if isMemberOf(resource.data.companyId) || isPlatformAdmin();
    }
    match /supportMessages/{supportMessageId} {
        // Simplified rule: allow if authenticated.
        allow read, write: if authed();
    }

    // EQUIPMENT: Publicly readable, but only members of the provider company can write.
    match /equipment/{equipmentId} {
      allow read: if true;
      allow write: if isMemberOf(resource.data.providerId) || isPlatformAdmin();
    }
    
    // REVIEWS: Anyone can read. Only authenticated users can create. Admins can update/delete.
    match /reviews/{reviewId} {
      allow get, list: if true;
      allow create: if authed();
      allow update, delete: if isPlatformAdmin();
    }

    // -------- Top-Level Public & Admin Collections --------
    match /userAuditLogs/{logId} { allow read, write: if isPlatformAdmin(); }
    match /jobAuditLogs/{logId} { allow read, write: if isPlatformAdmin(); }
    match /billingAuditLogs/{logId} { allow read, write: if isPlatformAdmin(); }
    match /payments/{paymentId} { allow read, write: if isPlatformAdmin(); }
    match /subscriptions/{subId} { allow read, write: if isPlatformAdmin(); }
    match /jobPayments/{jobPaymentId} { allow read, write: if isPlatformAdmin(); }
    
    match /techniques/{techId} { allow read: if true; allow write: if isPlatformAdmin(); }
    match /manufacturers/{manuId} { allow read: if true; allow write: if isPlatformAdmin(); }
    match /products/{prodId} { allow read: if true; allow write: if isPlatformAdmin(); }
    match /plans/{planId} { allow read: if true; allow write: if isPlatformAdmin(); }
    match /events/{eventId} { allow read: if true; allow write: if isPlatformAdmin(); }
  }
}

    