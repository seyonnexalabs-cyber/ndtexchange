
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -------- Helpers --------
    function authed() {
      return request.auth != null;
    }
    function isPlatformAdmin() {
      return authed() && (request.auth.uid in ['i947NWP5Hfb3Tpe5P6XcrjODRIJ2', '8ulGMzDhV1VgocwqptGCpV6Dkkl1']);
    }
    function isSelf(userId) {
      return authed() && request.auth.uid == userId;
    }
    function isMemberOf(companyId) {
      // Use exists() instead of get() for better performance and to avoid read costs in rules.
      return authed() && exists(/databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid));
    }
    function getJobData(jobPath) {
      return get(jobPath).data;
    }

    // -------- USERS --------
    match /users/{userId} {
      allow read, update: if isSelf(userId) || isPlatformAdmin();
      allow create: if isSelf(userId);
      allow list, delete: if isPlatformAdmin();

      // User-specific subcollections are private
      match /{subcollection}/{docId} {
        allow read, write: if isSelf(userId);
      }
    }
    
    // -------- COMPANIES & ALL NESTED DATA --------
    match /companies/{companyId} {
      allow read: if authed();
      allow write: if isPlatformAdmin();
      
      match /members/{memberUid} {
        allow read, write: if isMemberOf(companyId) || isPlatformAdmin();
      }
      
      match /assets/{assetId} {
        allow read, write: if isMemberOf(companyId) || isPlatformAdmin();
        
        match /inspections/{inspectionId} {
          allow read, write: if isMemberOf(companyId) || isPlatformAdmin();
        }
      }
      
      match /jobs/{jobId} {
        allow get: if authed();
        allow list: if isMemberOf(companyId);
        allow write: if isMemberOf(companyId) || isMemberOf(getJobData(path(request.path)).providerCompanyId) || isPlatformAdmin();
        
        match /bids/{bidId} {
          // This rule allows a client to see the bids on their job, or an inspector to see their own bid.
          allow get: if isMemberOf(companyId) || isSelf(resource.data.inspectorId) || isPlatformAdmin();
          // This rule allows a client to list all bids for a specific job.
          allow list: if isMemberOf(companyId);
          // This rule allows an inspector to create their own bid, or a client to update a bid (e.g., to award it).
          allow write: if isSelf(request.resource.data.inspectorId) || isMemberOf(companyId) || isPlatformAdmin();
        }
        
        match /messages/{messageId} {
          allow read, write: if isMemberOf(companyId) || isMemberOf(getJobData(path(request.path)).providerCompanyId) || isPlatformAdmin();
        }
      }

      match /supportChats/{supportChatId} {
          allow read, write: if isMemberOf(companyId) || isPlatformAdmin();
          match /supportMessages/{messageId} {
              allow read, write: if isMemberOf(companyId) || isPlatformAdmin();
          }
      }
    }
    
    // -------- Top-Level Admin Collections --------
    match /userAuditLogs/{logId} { allow read, write: if isPlatformAdmin(); }
    match /jobAuditLogs/{logId} { allow read, write: if isPlatformAdmin(); }
    match /billingAuditLogs/{logId} { allow read, write: if isPlatformAdmin(); }
    match /payments/{paymentId} { allow read, write: if isPlatformAdmin(); }
    match /subscriptions/{subId} { allow read, write: if isPlatformAdmin(); }
    match /jobPayments/{jobPaymentId} { allow read, write: if isPlatformAdmin(); }
    
    // -------- Top-Level PUBLIC Collections --------
    match /techniques/{techId} { allow read: if true; allow write: if isPlatformAdmin(); }
    match /manufacturers/{manuId} { allow read: if true; allow write: if isPlatformAdmin(); }
    match /products/{prodId} { allow read: if true; allow write: if isPlatformAdmin(); }
    match /plans/{planId} { allow read: if true; allow write: if isPlatformAdmin(); }
    match /events/{eventId} { allow read: if true; allow write: if isPlatformAdmin(); }
    match /equipment/{equipmentId} { allow read: if true; allow write: if isPlatformAdmin() || isMemberOf(resource.data.providerId); }
    
    // -------- Reviews --------
    match /reviews/{reviewId} {
      allow get, list: if true;
      allow create: if authed();
      allow update, delete: if isPlatformAdmin();
    }
    
    // -------- COLLECTION GROUP QUERIES --------
    // These rules allow broad queries across all companies, which are then
    // filtered on the client-side by a `where()` clause. The security of these
    // queries relies on the client-side code ALWAYS including that filter.

    match /{path=**}/jobs/{jobId} {
        // Allows listing jobs for marketplaces (e.g., where('status', '==', 'Posted'))
        allow list: if authed();
    }
    
    match /{path=**}/bids/{bidId} {
        // This rule is CRITICAL. It allows an inspector to perform a `list` operation
        // (a query) across the entire 'bids' collection group.
        // The application query `where('inspectorId', '==', auth.uid)` ensures they
        // only get their own bids. This rule authorizes the *action* of querying.
        allow list: if authed();
    }
    
    match /{path=**}/inspections/{inspectionId} {
        // Allows inspectors/clients to query for all their inspections across different assets.
        allow list: if authed();
    }
  }
}
