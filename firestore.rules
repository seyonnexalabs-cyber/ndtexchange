
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Correctly checks the UID of the logged-in user against known admin UIDs.
      return isSignedIn() && (request.auth.uid == 'i947NWP5Hfb3Tpe5P6XcrjODRIJ2' || request.auth.uid == '8ulGMzDhV1VgocwqptGCpV6Dkkl1');
    }

    // --------------------------------
    // Collection Rules
    // --------------------------------

    match /users/{userId} {
      // Allow any signed-in user (including the seeder admin) to create a user account.
      // The signup flow also uses this, where the user is already authenticated.
      allow create: if isSignedIn();
      
      // Any signed-in user can view a profile.
      allow get: if isSignedIn();
      
      // Only the user themselves or an admin can update/delete their own profile.
      allow update, delete: if isOwner(userId) || isAdmin();
      
      // Listing users is restricted to admins for security.
      allow list: if isAdmin();
    }

    match /companies/{companyId} {
      // Admin can create companies. Users can create their own company during signup.
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.contactEmail == request.auth.token.email);
      // Publicly readable.
      allow read: if true;
      // Only admins can modify company data after creation.
      allow write: if isAdmin();

      match /supportChats/{chatId} {
        allow read, write: if isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == companyId;
        
        match /supportMessages/{messageId} {
          allow read, write: if isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == companyId;
        }
      }
    }
    
    match /assets/{assetId} {
      // Create allowed for admins or any signed-in user creating an inspection for this asset.
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.companyId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId);
      // Read/update/delete requires checking the existing document
      allow read, update, delete: if isAdmin() || (resource.data.companyId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId);
      
      match /inspections/{inspectionId} {
        // Create allowed for admins or any signed-in user creating an inspection for this asset.
        allow create: if isAdmin() || isSignedIn();
        // Reads are allowed by company members or the assigned inspector.
        allow read: if (get(/databases/$(database)/documents/assets/$(assetId)).data.companyId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId) || isOwner(resource.data.inspectorId);
        // Writes only by admin or the assigned inspector.
        allow update, delete: if isAdmin() || isOwner(resource.data.inspectorId);
      }
    }

    match /jobs/{jobId} {
      // Admin can seed. A user can create a job if the clientId in the job data is their own UID.
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.clientId == request.auth.uid);
      
      // Jobs are public to find and bid on.
      allow read: if true;
      
      // Update/delete is restricted.
      allow update: if isAdmin() || (resource.data.clientCompanyId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId) || (resource.data.awardedProviderId != null && resource.data.awardedProviderId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId);
      allow delete: if isAdmin() || (resource.data.clientCompanyId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId);

      match /bids/{bidId} {
        // Admin can seed. An inspector can create a bid if they are the owner of the bid.
        allow create: if isAdmin() || (isSignedIn() && request.resource.data.inspectorId == request.auth.uid);
        
        allow read: if isAdmin() || isOwner(resource.data.inspectorId) || (get(/databases/$(database)/documents/jobs/$(jobId)).data.clientCompanyId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId);
        allow update, delete: if isAdmin() || isOwner(resource.data.inspectorId);
      }
      
      match /messages/{messageId} {
         allow read, write: if (
          let job = get(/databases/$(database)/documents/jobs/$(jobId)).data;
          let userCompanyId = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId;
          (userCompanyId == job.clientCompanyId || (job.awardedProviderId != null && userCompanyId == job.awardedProviderId))
        ) || isAdmin();
      }
    }

    match /reports/{reportId} {
        // Creating a report is tied to an existing inspection, handled by app logic.
        // Admins can seed. Any signed-in user can create a report document.
        allow create: if isAdmin() || isSignedIn();
        
        function canAccessReport() {
            let asset = get(/databases/$(database)/documents/assets/$(resource.data.assetId)).data;
            return isOwner(resource.data.inspectorId) || (asset.companyId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId) || isOwner(resource.data.level3ApproverId);
        }
        allow read: if isAdmin() || canAccessReport();
        allow update, delete: if isAdmin() || isOwner(resource.data.inspectorId);
    }
    
    // All other collections that are either public or admin-only
    match /asset_types/{assetTypeId} { allow read: if true; allow write: if isAdmin(); }
    match /techniques/{techniqueId} { allow read: if true; allow write: if isAdmin(); }
    match /manufacturers/{manufacturerId} { allow read: if true; allow write: if isAdmin(); }
    match /equipment/{equipmentId} { allow read: if true; allow write: if isAdmin(); }
    match /defects/{defectId} { allow read, write: if isAdmin(); }
    match /subscriptions/{subscriptionId} { allow read, write: if isAdmin(); }
    match /roles_admin/{userId} { allow read, write: if isAdmin(); }
    match /payments/{paymentId} { allow read, write: if isAdmin(); }
    match /jobPayments/{paymentId} { allow read, write: if isAdmin(); }
    match /reviews/{reviewId} { allow read: if true; allow write: if isAdmin(); allow create: if isSignedIn(); }
    match /userAuditLogs/{logId} { allow read, write: if isAdmin(); }
    match /jobAuditLogs/{logId} { allow read, write: if isAdmin(); }
    match /billingAuditLogs/{logId} { allow read, write: if isAdmin(); }
  }
}
