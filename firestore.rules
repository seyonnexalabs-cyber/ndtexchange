
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // --- Path-based Rules ---

    // USER DATA: Users can only access their own data.
    match /users/{userId}/{documents=**} {
      allow read, write: if isOwner(userId);
    }

    // PUBLIC DATA: Logged-in users can read these collections.
    match /companies/{companyId} { allow read: if isSignedIn(); }
    match /techniques/{techniqueId} { allow read: if isSignedIn(); }
    match /manufacturers/{manufacturerId} { allow read: if isSignedIn(); }
    match /products/{productId} { allow read: if isSignedIn(); }
    match /reviews/{reviewId} { allow read: if isSignedIn(); }
    
    // JOB DATA: Access is based on role within the job.
    match /jobs/{jobId} {
      allow get: if isSignedIn() && (
        isOwner(resource.data.userId) || // Client who created the job
        getUserData().companyId == resource.data.providerCompanyId // Assigned provider
      );
      
      // Allow any signed-in user to see posted jobs (for the marketplace).
      allow list: if isSignedIn();

      // Client can create/update jobs, assigned provider can update status.
      allow write: if isSignedIn() && (
        isOwner(request.resource.data.userId) ||
        getUserData().companyId == request.resource.data.providerCompanyId
      );
      
      // MESSAGES
      match /messages/{messageId} {
        allow read, write: if isSignedIn() && (
            isOwner(get(/databases/$(database)/documents/jobs/$(jobId)).data.userId) ||
            getUserData().companyId == get(/databases/$(database)/documents/jobs/$(jobId)).data.providerCompanyId
        );
      }
    }

    // BIDS: Top-level collection for simple queries
    match /bids/{bidId} {
        // An inspector can read/write their own bid. A client can read/update bids on their jobs.
        allow read, update: if isSignedIn() && (request.auth.uid == resource.data.inspectorId || request.auth.uid == resource.data.userId);
        
        // An inspector can create a bid.
        allow create: if isSignedIn() && request.auth.uid == request.resource.data.inspectorId;
    }
    
    // ASSET DATA: Access based on company ownership.
    match /assets/{assetId} {
      allow read, write: if isSignedIn() && getUserData().companyId == resource.data.companyId;

      match /inspections/{inspectionId} {
        allow read, write: if isSignedIn() && getUserData().companyId == get(/databases/$(database)/documents/assets/$(assetId)).data.companyId;
      }
    }

    // --- ADMIN-ONLY DATA ---
    // These collections are locked down and require admin role.
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }
    
    match /roles_admin/{userId} { allow read: if isSignedIn(); }
    match /jobPayments/{paymentId} { allow read, write: if isAdmin(); }
    match /payments/{paymentId} { allow read, write: if isAdmin(); }
    match /billingAuditLogs/{logId} { allow read: if isAdmin(); }
    match /jobAuditLogs/{logId} { allow read: if isAdmin(); }
    match /userAuditLogs/{logId} { allow read: if isAdmin(); }
  }
}
