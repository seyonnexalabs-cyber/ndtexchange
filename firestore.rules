
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -------- Helpers --------
    function authed() { return request.auth != null; }
    function myUid() { return request.auth.uid; }

    function isPlatformAdmin() {
      // Allow seeding for specific admin UIDs without checking custom claims,
      // which might not exist during the seeding batch write.
      return authed() && (
        request.auth.uid == 'i947NWP5Hfb3Tpe5P6XcrjODRIJ2' ||
        get(/databases/$(database)/documents/users/$(myUid())).data.role == 'Admin'
      );
    }
    
    function isSelf(userId) {
      return authed() && myUid() == userId;
    }
    
    function isMemberOf(companyId) {
        return authed() && get(/databases/$(database)/documents/users/$(myUid())).data.companyId == companyId;
    }

    // -------- USERS --------
    match /users/{userId} {
      allow list: if isPlatformAdmin();
      allow read: if isSelf(userId) || isPlatformAdmin();
      
      allow create: if isSelf(userId) && !('role' in request.resource.data);

      allow update: if (isSelf(userId) && !('role' in request.resource.data)) || isPlatformAdmin();
      
      allow delete: if isPlatformAdmin();

      match /tasks/{taskId} {
        allow read, write: if isSelf(userId) || isPlatformAdmin();
      }
      match /notifications/{notificationId} {
        allow read, write: if isSelf(userId) || isPlatformAdmin();
      }
    }
    
    // -------- COMPANIES & NESTED DATA --------
    match /companies/{companyId} {
      allow read: if true;
      allow write: if isPlatformAdmin();
      
      match /members/{memberUid} {
        allow read, write: if isMemberOf(companyId) || isPlatformAdmin();
      }
      
      match /assets/{assetId} {
        allow read, write: if isMemberOf(companyId) || isPlatformAdmin();
        
        match /inspections/{inspectionId} {
          allow read, write: if isMemberOf(companyId) || isPlatformAdmin();
        }
      }
      
      match /jobs/{jobId} {
        function isJobParticipant() {
          let job = resource.data;
          let providerCompanyId = job.keys().hasAll(['providerCompanyId']) ? job.providerCompanyId : null;
          let auditorCompanyId = job.keys().hasAll(['auditorCompanyId']) ? job.auditorCompanyId : null;
          
          return isMemberOf(companyId) // Client company
              || (providerCompanyId != null && isMemberOf(providerCompanyId))
              || (auditorCompanyId != null && isMemberOf(auditorCompanyId));
        }
        
        allow list: if isMemberOf(companyId) || isPlatformAdmin();
        allow get, write: if isJobParticipant() || isPlatformAdmin();
        
        match /bids/{bidId} {
          allow read, write: if isJobParticipant() || isPlatformAdmin();
        }
        
        match /messages/{messageId} {
          allow read, write: if isJobParticipant() || isPlatformAdmin();
        }
      }

      match /reviews/{reviewId} {
        allow read: if authed();
        allow write: if isPlatformAdmin() || isMemberOf(companyId);
      }
       match /supportChats/{supportChatId} {
          allow read, write: if isMemberOf(companyId) || isPlatformAdmin();
          match /supportMessages/{messageId} {
              allow read, write: if isMemberOf(companyId) || isPlatformAdmin();
          }
      }
    }
    
    // -------- Top-Level Admin Collections --------
    match /userAuditLogs/{logId} { allow read, write: if isPlatformAdmin(); }
    match /jobAuditLogs/{logId} { allow read, write: if isPlatformAdmin(); }
    match /billingAuditLogs/{logId} { allow read, write: if isPlatformAdmin(); }
    match /payments/{paymentId} { allow read, write: if isPlatformAdmin(); }
    match /subscriptions/{subId} { allow read, write: if isPlatformAdmin(); }
    match /jobPayments/{jobPaymentId} { allow read, write: if isPlatformAdmin(); }
    
    // -------- Top-Level PUBLIC Collections --------
    match /techniques/{techId} { allow read: if true; allow write: if isPlatformAdmin(); }
    match /manufacturers/{manuId} { allow read: if true; allow write: if isPlatformAdmin(); }
    match /products/{prodId} { allow read: if true; allow write: if isPlatformAdmin(); }
    match /plans/{planId} { allow read: if true; allow write: if isPlatformAdmin(); }
    match /events/{eventId} { allow read: if true; allow write: if isPlatformAdmin(); }

    // -------- Collection Group Queries --------
    match /{path=**}/jobs/{jobId} {
      allow read: if authed() || isPlatformAdmin();
    }
    match /{path=**}/reviews/{reviewId} {
      allow read: if authed() || isPlatformAdmin();
    }
    match /{path=**}/bids/{bidId} {
      allow read: if authed() || isPlatformAdmin();
    }
     match /{path=**}/inspections/{inspectionId} {
      allow read: if authed() || isPlatformAdmin();
    }
  }
}
