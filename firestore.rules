
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // This is a temporary, insecure rule for diagnostic purposes ONLY.
    // Its goal is to prove that the 'bids' query can run without interference
    // from other rules in the file.
    match /{path=**}/bids/{bidId} {
      allow read: if request.auth != null;
    }

    // By default, all other access is denied. This may cause other
    // parts of the app to show errors, which is expected during this test.
  }
}
