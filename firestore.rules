
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -------- Helpers --------
    function authed() { return request.auth != null; }
    function myUid() { return request.auth.uid; }

    // Global platform admin (super admin)
    function isPlatformAdmin() {
      // Allow seeding for specific admin UIDs without checking custom claims,
      // which might not exist during the seeding batch write.
      return authed() && (
        request.auth.uid == 'i947NWP5Hfb3Tpe5P6XcrjODRIJ2' ||
        get(/databases/$(database)/documents/users/$(myUid())).data.role == 'Admin'
      );
    }

    function myCompany() {
      let userProfile = get(/databases/$(database)/documents/users/$(myUid()));
      if (userProfile.data.keys().hasAll(['companyId'])) {
        return userProfile.data.companyId;
      }
      return null;
    }
    
    function isSelf(uid) {
      return authed() && myUid() == uid;
    }
    
    function isMember(companyId) {
      return authed() && exists(/databases/$(database)/documents/companies/$(companyId)/members/$(myUid()));
    }
    
    function roleInCompany(companyId) {
      return authed() ? get(/databases/$(database)/documents/companies/$(companyId)/members/$(myUid())).data.roleInCompany : null;
    }

    function isCompanyAdmin(companyId) {
      return authed() && (
        roleInCompany(companyId) in ['Owner', 'Manager']
      );
    }

    // -------- USERS --------
    match /users/{userId} {
      // Read own profile; admins can read all.
      allow read: if isSelf(userId) || isPlatformAdmin();
      
      // Anyone can create their own user doc, but not set privileged fields
      allow create: if isSelf(userId) && !('role' in request.resource.data);

      // User can update their own non-privileged fields; admins can update anything
      allow update: if (isSelf(userId) && !('role' in request.resource.data)) || isPlatformAdmin();
      
      // Admins can delete users
      allow delete: if isPlatformAdmin();

      // User-owned subcollections for tasks and notifications
      match /tasks/{taskId} {
        allow read, write: if isSelf(userId) || isPlatformAdmin();
      }
      match /notifications/{notificationId} {
        allow read, write: if isSelf(userId) || isPlatformAdmin();
      }
    }
    
    // -------- COMPANIES & NESTED DATA --------
    match /companies/{companyId} {
      allow read: if authed();
      allow write: if isPlatformAdmin();
      
      match /members/{memberUid} {
        allow read: if isMember(companyId) || isPlatformAdmin();
        allow write: if isCompanyAdmin(companyId) || isPlatformAdmin();
      }
      
      match /assets/{assetId} {
        allow read, write: if isMember(companyId) || isPlatformAdmin();
        
        match /inspections/{inspectionId} {
          allow read, write: if isMember(companyId) || isPlatformAdmin();
        }
      }
      
      match /jobs/{jobId} {
        function isJobParticipant() {
          let job = resource.data;
          let providerCompanyId = job.keys().hasAll(['providerCompanyId']) ? job.providerCompanyId : null;
          let auditorCompanyId = job.keys().hasAll(['auditorCompanyId']) ? job.auditorCompanyId : null;
          let myCompanyId = myCompany();

          return myCompanyId == companyId // Client company
              || (providerCompanyId != null && myCompanyId == providerCompanyId)
              || (auditorCompanyId != null && myCompanyId == auditorCompanyId);
        }
        
        allow read, write: if isJobParticipant() || isPlatformAdmin();
        
        match /bids/{bidId} {
          allow read, write: if isJobParticipant() || isPlatformAdmin();
        }
        
        match /messages/{messageId} {
          allow read, write: if isJobParticipant() || isPlatformAdmin();
        }
      }

      match /reviews/{reviewId} {
        allow read: if authed();
        allow write: if isPlatformAdmin() || isMember(companyId);
      }
    }
    
    // -------- Top-Level Admin Collections --------
    match /userAuditLogs/{logId} { allow read, write: if isPlatformAdmin(); }
    match /jobAuditLogs/{logId} { allow read, write: if isPlatformAdmin(); }
    match /billingAuditLogs/{logId} { allow read, write: if isPlatformAdmin(); }
    match /payments/{paymentId} { allow read, write: if isPlatformAdmin(); }
    match /subscriptions/{subId} { allow read, write: if isPlatformAdmin(); }
    match /jobPayments/{jobPaymentId} { allow read, write: if isPlatformAdmin(); }
    
    // -------- Top-Level PUBLIC Collections --------
    match /techniques/{techId} { allow read: if authed(); allow write: if isPlatformAdmin(); }
    match /manufacturers/{manuId} { allow read: if authed(); allow write: if isPlatformAdmin(); }
    match /products/{prodId} { allow read: if authed(); allow write: if isPlatformAdmin(); }
    match /plans/{planId} { allow read: if authed(); allow write: if isPlatformAdmin(); }

    // -------- Catalog Collections --------
    match /catalog/{category}/{docId} {
        allow read: if authed();
        allow write: if isPlatformAdmin();
    }

    // -------- Collection Group Queries --------
    match /{path=**}/jobs/{jobId} {
      allow read: if isPlatformAdmin();
    }
    match /{path=**}/reviews/{reviewId} {
      allow read: if isPlatformAdmin() || authed();
    }
    match /{path=**}/bids/{bidId} {
      allow read: if isPlatformAdmin() || (authed() && resource.data.inspectorId == myUid());
    }
    match /{path=**}/inspections/{inspectionId} {
      allow read: if isPlatformAdmin();
    }
  }
}
