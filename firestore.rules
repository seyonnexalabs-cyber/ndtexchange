
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // This is the definitive way to check for admin.
    // UIDs are for admin@ndtexchange.com and seyonnexalabs@gmail.com
    function isAdmin() {
      return isSignedIn() && (request.auth.uid == 'i947NWP5Hfb3Tpe5P6XcrjODRIJ2' || request.auth.uid == '8ulGMzDhV1VgocwqptGCpV6Dkkl1');
    }

    function getUserCompanyId() {
      // Safely get the user's company ID, returning null if not found.
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      if (userDoc != null && 'companyId' in userDoc.data) {
        return userDoc.data.companyId;
      }
      return null;
    }

    // --------------------------------
    // Collection Rules
    // --------------------------------

    match /users/{userId} {
      allow write: if isAdmin(); // Admin can seed
      allow create: if isOwner(userId);
      allow get: if isSignedIn(); // Allow any signed-in user to read any profile for rule lookups.
      allow list: if isAdmin(); // Only admins can list users
      allow update, delete: if isOwner(userId);

      // FCM tokens can only be managed by the owner
      match /fcmTokens/{token} {
        allow read, write: if isOwner(userId);
      }

      // Notifications can only be read and updated by the owner
      match /notifications/{notificationId} {
        allow read, update: if isOwner(userId);
        // Only allow admin to create/delete notifications, not the user client-side
        allow create, delete: if isAdmin();
      }
    }

    match /companies/{companyId} {
      allow write: if isAdmin(); // Admin can seed
      // Admins or the initial company contact can create a company document.
      allow create: if (isSignedIn() && request.resource.data.contactEmail == request.auth.token.email);
      // All company documents are publicly readable.
      allow read: if true;
      // Only admins can modify company data.
      allow update: if isAdmin();

      match /supportChats/{chatId} {
        allow write: if isAdmin(); // Admin can seed
        // Only members of the company or admins can access support chats.
        allow read, write: if getUserCompanyId() == companyId;
        
        match /supportMessages/{messageId} {
          allow write: if isAdmin(); // Admin can seed
          allow read, write: if getUserCompanyId() == companyId;
        }
      }
    }
    
    match /assets/{assetId} {
      allow write: if isAdmin(); // Admin can seed
      // A user can create an asset for their own company.
      allow create: if (isSignedIn() && request.resource.data.companyId == getUserCompanyId());
      // Listing is allowed, and secured by client-side queries.
      allow list: if isSignedIn();
      // A user can read, update, or delete an asset IFF they belong to that asset's company.
      allow get, update, delete: if (isSignedIn() && resource.data.companyId == getUserCompanyId());
      
      match /inspections/{inspectionId} {
        allow write: if isAdmin(); // Admin can seed
        // Creating an inspection is allowed if you are a member of the asset's company.
        allow create: if (isSignedIn() && get(/databases/$(database)/documents/assets/$(assetId)).data.companyId == getUserCompanyId());
        // You can get an inspection if you are the inspector or a member of the asset's owning company.
        allow get: if isSignedIn() && (isOwner(resource.data.inspectorId) || get(/databases/$(database)/documents/assets/$(assetId)).data.companyId == getUserCompanyId());
        // You can list inspections if you are a member of the asset's owning company.
        allow list: if isSignedIn() && get(/databases/$(database)/documents/assets/$(assetId)).data.companyId == getUserCompanyId();
        // Only the assigned inspector or an admin can update/delete.
        allow update, delete: if isOwner(resource.data.inspectorId) || isAdmin();
      }
    }

    match /jobs/{jobId} {
      allow write: if isAdmin(); // Admin can seed
      // A signed-in user can create a job if they are the client.
      allow create: if (isSignedIn() && request.resource.data.clientId == request.auth.uid);
      // All jobs are publicly readable for marketplace browsing.
      allow read, list: if isSignedIn();
      // Only the client, the awarded provider, or an admin can update a job.
      allow update: if (isSignedIn() && (getUserCompanyId() == resource.data.clientCompanyId || getUserCompanyId() == resource.data.awardedProviderId));
      // Only the client or an admin can delete a job.
      allow delete: if (isSignedIn() && getUserCompanyId() == resource.data.clientCompanyId);

      match /bids/{bidId} {
        allow write: if isAdmin(); // Admin can seed
        // An inspector can create a bid for their own user ID.
        allow create: if (isSignedIn() && request.resource.data.inspectorId == request.auth.uid);
        // The job client, the bidding inspector, or an admin can read bids.
        allow read: if isSignedIn() && (isOwner(resource.data.inspectorId) || getUserCompanyId() == get(/databases/$(database)/documents/jobs/$(jobId)).data.clientCompanyId);
        // Only the bidding inspector can update/delete.
        allow update, delete: if isOwner(resource.data.inspectorId);
      }
      
      match /messages/{messageId} {
        allow write: if isAdmin(); // Admin can seed
        // Participants of the job can read messages and create new ones.
        allow read, create: if isSignedIn() && (
            (exists(/databases/$(database)/documents/jobs/$(jobId)) && (
                (getUserCompanyId() == get(/databases/$(database)/documents/jobs/$(jobId)).data.clientCompanyId) ||
                (getUserCompanyId() == get(/databases/$(database)/documents/jobs/$(jobId)).data.awardedProviderId)
              ))
        );
      }
    }

    match /reports/{reportId} {
      allow write: if isAdmin(); // Admin can seed
      // Any signed-in user can create a report document.
      allow create: if isSignedIn();
      // Access to reports is determined by involvement in the job/asset.
      allow read: if isSignedIn();
      allow update, delete: if isOwner(resource.data.inspectorId);
    }
    
    // All other collections that are either public or admin-only
    match /asset_types/{assetTypeId} { allow read: if true; allow write: if isAdmin(); }
    match /techniques/{techniqueId} { allow read: if true; allow write: if isAdmin(); }
    match /manufacturers/{manufacturerId} { allow read: if true; allow write: if isAdmin(); }
    match /equipment/{equipmentId} { allow read: if true; allow write: if isAdmin(); }
    match /defects/{defectId} { allow read, write: if isAdmin(); }
    match /subscriptions/{subscriptionId} { allow read, write: if isAdmin(); }
    match /roles_admin/{userId} { allow read, write: if isAdmin(); }
    match /payments/{paymentId} { allow read, write: if isAdmin(); }
    match /jobPayments/{paymentId} { allow read, write: if isAdmin(); }
    match /reviews/{reviewId} { allow read: if true; allow create: if isSignedIn() || isAdmin(); allow write: if isAdmin(); }
    match /userAuditLogs/{logId} { allow read, write: if isAdmin(); }
    match /jobAuditLogs/{logId} { allow read, write: if isAdmin(); }
    match /billingAuditLogs/{logId} { allow read, write: if isAdmin(); }
  }
}
    