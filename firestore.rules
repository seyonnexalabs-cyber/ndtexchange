
/**
 * # Core Philosophy
 * This ruleset enforces a security model based on user roles (Admin, Client, Inspector)
 * and direct ownership or participation in data. Administrative users, identified by
 * their email address, have elevated privileges. For all other users, access is
 * granted based on specific fields within documents, such as `clientId` on a Job,
 * `inspectorId` on an Inspection, or `senderId`/`receiverId` on a Message.
 *
 * # Data Structure
 * The data is organized into several top-level collections representing the core
 * entities of the application (users, assets, jobs, etc.). This flat structure is
 * chosen to simplify queries and security rules. Subcollections are used only when
 * data is intrinsically nested and always accessed in the context of its parent,
 * such as Bids within a Job.
 *
 * # Key Security Decisions
 * - Admin Access: A user is considered an admin if their authenticated email is
 *   one of the predefined admin emails. This is a fast and secure check.
 * - User Privacy: A user's own profile in `/users/{userId}` is strictly private.
 *   They are the only ones who can read or write their own document. Listing all
 *   users is disabled to protect user privacy (except for admins).
 * - Public Data: Collections like `/asset_types`, `/techniques`, `/manufacturers`, and `/companies` are considered public,
 *   readable by anyone, but writable only by admins.
 * - Shared Data: Access to shared documents like Jobs and Messages is controlled by
 *   UIDs stored directly on the document (e.g., `clientId`, `senderId`). This avoids
 *   complex lookups and ensures performant, secure access.
 *
 * # Denormalization for Authorization
 * To create simpler and more performant rules, authorization-critical data is
 * denormalized. For instance, instead of looking up a Job's owner to see a Bid, the
 * rules for a Bid will perform a direct `get()` on the parent Job document. Similarly,
 * a Report contains an `inspectorId`, and a Message contains a `senderId` and
 * `receiverId`, making authorization checks fast and self-contained without needing
 * joins or complex queries.
 *
 * # Structural Segregation
 * Data is segregated by its access pattern. For example, private user data is in
 * `/users/{userId}`, while public template data is in `/asset_types`. This is more
 * secure and efficient for list operations than mixing public and private data in a
 * single collection with a boolean flag.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the user's UID matches the provided userId.
     * This is the foundation of the ownership model.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the document being accessed already exists.
     * Crucial for protecting update and delete operations from acting on non-existent data.
     */
    function isExistingDoc() {
      return resource != null;
    }

    /**
     * Combines ownership and existence checks for update/delete operations.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && isExistingDoc();
    }

    /**
     * Checks if the requesting user has admin privileges.
     * It does this by checking for the authenticated user's email address.
     * This is a fast and non-recursive way to check for admin status.
     */
    function isAdmin() {
      return isSignedIn() && request.auth.token.email in ['admin@ndtexchange.com', 'seyonnexalabs@gmail.com'];
    }
    
    /**
     * Validates that the user is the creator of a resource on creation.
     */
    function isResourceCreator(key) {
      return request.resource.data[key] == request.auth.uid;
    }

    /**
     * Validates that a critical relational ID field is immutable on update.
     */
    function isImmutable(key) {
      return request.resource.data[key] == resource.data[key];
    }
    
    /**
     * Checks if the user is a member of a given company.
     */
    function isCompanyMember(companyId) {
        return exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == companyId;
    }

    // --------------------------------
    // Collection Rules
    // --------------------------------

    /**
     * @description Manages user profile data.
     * @path /users/{userId}
     * @allow (get) An authenticated user can read their own profile.
     * @deny (get) A user trying to read another user's profile directly.
     * @principle Restricts access to a user's own data tree, but allows an admin check.
     */
    match /users/{userId} {
      allow list, write: if isAdmin();
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isResourceCreator('id');
      allow update: if isExistingOwner(userId) || isAdmin();
      allow delete: if isExistingOwner(userId) || isAdmin();

      /**
       * @description Manages user-specific notifications.
       * @principle Grants read/write access based on ownership, enabling targeted client-side queries.
       */
      match /notifications/{notificationId} {
        allow read, write: if isOwner(userId);
      }
    }

    /**
     * @description Manages core asset data.
     * @path /assets/{assetId}
     * @allow (list) Any authenticated user can list assets, but queries must be filtered by companyId on the client.
     * @deny (create) Any user trying to create an asset for a company they do not belong to.
     * @principle Client queries are secured by companyId, writes are validated against user's company.
     */
    match /assets/{assetId} {
      allow create: if isAdmin() || isCompanyMember(request.resource.data.companyId);
      allow read, write: if isAdmin() || isCompanyMember(resource.data.companyId);
      allow list: if isSignedIn();
    }

    /**
     * @description Manages asset type templates, which are publicly readable.
     * @path /asset_types/{assetTypeId}
     * @allow (get) Any user, including unauthenticated ones, can read asset types.
     * @deny (create) A non-admin user trying to create a new asset type.
     * @principle Public read with admin-only writes.
     */
    match /asset_types/{assetTypeId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    /**
     * @description Manages NDT techniques, which are publicly readable.
     * @path /techniques/{techniqueId}
     * @principle Public read with admin-only writes.
     */
    match /techniques/{techniqueId} {
        allow read: if true;
        allow write: if isAdmin();
    }
    
    /**
     * @description Manages NDT equipment manufacturers, which are publicly readable.
     * @path /manufacturers/{manufacturerId}
     * @principle Public read with admin-only writes.
     */
    match /manufacturers/{manufacturerId} {
        allow read: if true;
        allow write: if isAdmin();
    }

    /**
     * @description Manages inspection records for a specific asset.
     * @path /assets/{assetId}/inspections/{inspectionId}
     * @allow (create) An inspector creating an inspection for an asset.
     * @deny (get) A user who is not the inspector or an admin trying to read an inspection.
     * @principle Secures a subcollection based on roles denormalized onto the document.
     */
    match /assets/{assetId}/inspections/{inspectionId} {
      // Access depends on being an admin or the designated inspector. Asset ownership check is pending schema update.
      allow read, write: if isAdmin();
      allow get, list: if isOwner(resource.data.inspectorId);
      allow create: if isSignedIn() && isResourceCreator('inspectorId');
      allow update: if isExistingOwner(resource.data.inspectorId) && isImmutable('inspectorId');
      allow delete: if isExistingOwner(resource.data.inspectorId);
    }

    /**
     * @description Manages detailed inspection reports.
     * @path /reports/{reportId}
     * @allow (get) The inspector or Level 3 approver reading the report.
     * @deny (update) The inspector trying to change the Level 3 approver ID.
     * @principle Shared access based on multiple participant roles stored on the document.
     */
    match /reports/{reportId} {
      function isReportParticipant() {
        return isOwner(resource.data.inspectorId) || isOwner(resource.data.level3ApproverId);
      }
      allow read, write: if isAdmin();
      allow get, list: if isReportParticipant();
      allow create: if isSignedIn() && isResourceCreator('inspectorId');
      allow update: if isReportParticipant() && isExistingDoc() && isImmutable('inspectionId') && isImmutable('inspectorId');
      allow delete: if isReportParticipant() && isExistingDoc();
    }

    /**
     * @description Manages defects found during an inspection.
     * @path /defects/{defectId}
     * @allow (get) An inspector reading a defect linked to a report they are assigned to.
     * @deny (create) A user trying to create a defect for a report they are not part of.
     * @principle Grants access based on a lookup to a related document.
     */
    match /defects/{defectId} {
      function canAccessRelatedReport(reportId) {
        let report = get(/databases/$(database)/documents/reports/$(reportId)).data;
        return request.auth.uid == report.inspectorId || request.auth.uid == report.level3ApproverId;
      }
      allow read, write: if isAdmin();
      allow get: if canAccessRelatedReport(resource.data.reportId);
      allow list: if isAdmin(); // Listing all defects is admin-only. Query by reportId instead.
      allow create: if isSignedIn() && canAccessRelatedReport(request.resource.data.reportId);
      allow update, delete: if canAccessRelatedReport(resource.data.reportId) && isExistingDoc();
    }

    /**
     * @description Manages job postings in the marketplace.
     * @path /jobs/{jobId}
     * @allow (get) Any authenticated user can read job details.
     * @deny (update) The awarded inspector trying to change the client ID.
     * @principle Shared access model where a creator and an assigned user can interact.
     */
    match /jobs/{jobId} {
      function isJobParticipant() {
        return isOwner(resource.data.clientId) || isOwner(resource.data.awardedInspectorId);
      }
      allow read: if true;
      allow write: if isAdmin();
      allow create: if isSignedIn() && isResourceCreator('clientId');
      allow update: if (isJobParticipant() || isAdmin()) && isExistingDoc() && isImmutable('clientId');
      allow delete: if (isOwner(resource.data.clientId) || isAdmin()) && isExistingDoc();
    }

    /**
     * @description Manages bids submitted by inspectors for jobs.
     * @path /jobs/{jobId}/bids/{bidId}
     * @allow (get) The job's client or the inspector who made the bid can read it.
     * @deny (get) Another inspector trying to read a competitor's bid.
     * @principle Subcollection access is determined by ownership of the bid and ownership of the parent document.
     */
    match /jobs/{jobId}/bids/{bidId} {
      function isJobClient() {
        return isOwner(get(/databases/$(database)/documents/jobs/$(jobId)).data.clientId);
      }
      allow read, write: if isAdmin();
      allow read: if isJobClient() || isOwner(resource.data.inspectorId);
      allow create: if isSignedIn() && isResourceCreator('inspectorId');
      allow update: if isExistingOwner(resource.data.inspectorId) && isImmutable('inspectorId') && isImmutable('jobId');
      allow delete: if isExistingOwner(resource.data.inspectorId) || isAdmin();
    }
    
     /**
     * @description Manages NDT provider equipment inventory.
     * @path /equipment/{equipmentId}
     * @principle A user can manage equipment if they belong to the provider company that owns it.
     */
    match /equipment/{equipmentId} {
        allow create: if isAdmin() || isCompanyMember(request.resource.data.providerId);
        allow read, write: if isAdmin() || isCompanyMember(resource.data.providerId); 
    }

    /**
     * @description Manages direct messages between two users.
     * @principle Grants read access only to participants of the message. Queries must be constrained.
     */
    match /messages/{messageId} {
      // A user can read a message if they are the sender or receiver.
      // This applies to both GET and LIST requests. LIST queries MUST
      // include a `where` clause constraining on senderId or receiverId.
      allow read: if request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId || isAdmin();
      
      // A user can create a message if they are the sender.
      allow create: if isResourceCreator('senderId');
      
      // Only the receiver can update a message (e.g., to mark as read).
      allow update: if isOwner(resource.data.receiverId) || isAdmin();
      
      // Disallow deletes for message history integrity.
      allow delete: if false;
    }
    
     /**
     * @description Manages real-time chats for support and job communication.
     * @path /chats/{chatId}/messages/{messageId}
     * @principle Allows participants of a chat to read and write messages. Admin has full access for moderation.
     */
    match /chats/{chatId} {
      allow write: if isAdmin();
      allow read, list: if isAdmin() || isCompanyMember(resource.data.companyId);
      
      match /messages/{messageId} {
        allow write: if isAdmin() || isCompanyMember(get(/databases/$(database)/documents/chats/$(chatId)).data.companyId);
        allow read: if isAdmin() || isCompanyMember(get(/databases/$(database)/documents/chats/$(chatId)).data.companyId);
      }
    }
    
    /**
     * @description Manages company profiles (Clients, Providers, Auditors), which are publicly readable.
     * @path /companies/{companyId}
     * @allow (get, list) Any user, including unauthenticated ones, can read company profiles.
     * @deny (create, update, delete) A non-admin user trying to modify company data.
     * @principle Public read with admin-only writes for directory functionality.
     */
    match /companies/{companyId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.token.email == request.resource.data.contactEmail;
      allow write: if isAdmin();
    }

    /**
     * @description Manages company subscription plans. Admin-only.
     * @path /subscriptions/{subscriptionId}
     * @principle Grants full access to administrators for billing management.
     */
    match /subscriptions/{subscriptionId} {
      allow read, write: if isAdmin();
    }
    
    /**
     * @description Manages admin role assignments. Admin-only.
     * @path /roles_admin/{userId}
     * @principle Grants full access to administrators for role management.
     */
    match /roles_admin/{userId} {
      allow read, write: if isAdmin();
    }

    /**
     * @description Manages payment records for subscriptions. Admin-only.
     * @path /payments/{paymentId}
     * @principle Grants full access to administrators for financial oversight.
     */
    match /payments/{paymentId} {
      allow read, write: if isAdmin();
    }

    /**
     * @description Manages payment records for specific jobs. Admin-only.
     * @path /jobPayments/{paymentId}
     * @principle Grants full access to administrators for financial oversight.
     */
    match /jobPayments/{paymentId} {
      allow read, write: if isAdmin();
    }

    /**
     * @description Manages client reviews of providers.
     * @path /reviews/{reviewId}
     * @allow (get, list) Any user can read reviews, enabling public display.
     * @allow (create) A user can create a review if they are the client on the job.
     * @deny (update) A user cannot update a review unless they are an admin.
     * @principle Admin moderation of user-generated content.
     */
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if isAdmin();
      allow create: if isSignedIn() && isResourceCreator('clientId');
    }
    
    /**
     * @description Manages audit logs. Admin-only access.
     * @principle Restricts sensitive historical data to administrators.
     */
    match /userAuditLogs/{logId} {
      allow read, list, write: if isAdmin();
    }

    match /jobAuditLogs/{logId} {
      allow read, list, write: if isAdmin();
    }

    match /billingAuditLogs/{logId} {
      allow read, list, write: if isAdmin();
    }

  }
}
