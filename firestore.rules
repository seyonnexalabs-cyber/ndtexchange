
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------
    //  Helper Functions
    // ---------------------------
    function authed() {
      return request.auth != null;
    }

    function isPlatformAdmin() {
      return authed() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function getRequestingUserData() {
      return getUserData(request.auth.uid);
    }
    
    function isCompanyMember(companyId) {
        let userData = getRequestingUserData();
        return authed() && userData != null && userData.companyId == companyId;
    }
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isJobParticipant(jobId) {
        let job = get(/databases/$(database)/documents/jobs/$(jobId)).data;
        let userData = getRequestingUserData();
        return userData != null && (userData.companyId == job.clientCompanyId || 
                (job.providerCompanyId != null && userData.companyId == job.providerCompanyId) ||
                (job.auditorCompanyId != null && userData.companyId == job.auditorCompanyId));
    }

    // ---------------------------
    //  Public Directories (Read-Only for non-admins)
    // ---------------------------
    match /techniques/{docId} {
      allow read: if true;
      allow write: if isPlatformAdmin();
    }
    match /manufacturers/{docId} {
      allow read: if true;
      allow write: if isPlatformAdmin();
    }
    match /products/{docId} {
      allow read: if true;
      allow write: if isPlatformAdmin();
    }
    match /plans/{docId} {
      allow read: if true;
      allow write: if isPlatformAdmin();
    }
     match /events/{docId} {
      allow read: if true;
      allow write: if isPlatformAdmin();
    }

    // ---------------------------
    //  User-Specific Collections
    // ---------------------------
    match /users/{userId} {
      allow read: if authed(); // Any logged-in user can read profiles (for names, etc)
      allow create: if isOwner(userId) || isPlatformAdmin(); // A user can create their own profile
      allow update: if isOwner(userId) || isPlatformAdmin(); // Only user or admin can update
      allow delete: if isPlatformAdmin();
    }
    
    match /tasks/{taskId} {
      allow read, write, delete: if isOwner(resource.data.userId) || isPlatformAdmin();
      allow create: if isOwner(request.resource.data.userId) || isPlatformAdmin();
    }
    
    match /designs/{designId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }

     match /tankDesigns/{designId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }

    // ---------------------------
    //  Company & Asset Collections
    // ---------------------------
    match /companies/{companyId} {
        allow read: if true; // Publicly readable for directories
        allow create: if (authed() && request.resource.data.contactEmail == request.auth.token.email) || isPlatformAdmin(); // Allow user to create their own company on signup
        allow update, delete: if isPlatformAdmin(); // Only admins can edit or delete
    }

    match /assets/{assetId} {
        allow read: if authed(); // Allow any auth'd user to read, access is controlled by pages
        allow create: if isCompanyMember(request.resource.data.companyId) || isPlatformAdmin();
        allow update, delete: if isCompanyMember(resource.data.companyId) || isPlatformAdmin();
    }

    match /equipment/{equipmentId} {
        allow read: if true; // Publicly readable for provider profiles
        // providerId is used here instead of companyId
        allow create: if isCompanyMember(request.resource.data.providerId) || isPlatformAdmin();
        allow update, delete: if isCompanyMember(resource.data.providerId) || isPlatformAdmin();
    }
    
    // ---------------------------
    //  Job Marketplace Collections
    // ---------------------------
    
    match /jobs/{jobId} {
      // Secure rule for fetching a single job document.
      allow get: if isJobParticipant(jobId) || isOwner(resource.data.userId) || resource.data.status == 'Posted' || isPlatformAdmin();

      // More permissive rule for listing/querying jobs. The client-side queries
      // are responsible for filtering to the correct company's jobs.
      allow list: if authed();

      allow create: if isCompanyMember(request.resource.data.clientCompanyId) || isCompanyMember(request.resource.data.providerCompanyId) || isPlatformAdmin();
      
      // Updates are complex: Client, Provider, or Admin can update.
      allow update: if isCompanyMember(resource.data.clientCompanyId) || 
                      (resource.data.providerCompanyId != null && isCompanyMember(resource.data.providerCompanyId)) ||
                      isPlatformAdmin();
                      
      allow delete: if isPlatformAdmin();

      // Nested Messages collection for real-time chat within a job
      match /messages/{messageId} {
          allow read, delete: if isJobParticipant(jobId) || isPlatformAdmin();
          allow create: if (isJobParticipant(jobId) && request.resource.data.senderId == request.auth.uid) || isPlatformAdmin();
      }

      // Nested reports subcollection
      match /reports/{reportId} {
        allow read, write: if isJobParticipant(jobId) || isPlatformAdmin();
      }
    }
    
    match /bids/{bidId} {
        allow create: if isCompanyMember(request.resource.data.providerCompanyId) || isPlatformAdmin();
        allow read: if isOwner(resource.data.inspectorId) || isJobParticipant(resource.data.jobId) || isPlatformAdmin();
        allow update: if isOwner(resource.data.inspectorId) || 
                      isCompanyMember(request.resource.data.clientCompanyId) ||
                      isPlatformAdmin();
    }
    
    match /inspections/{inspectionId} {
        allow create: if isCompanyMember(request.resource.data.clientCompanyId) || isPlatformAdmin();

        // Secure rule for fetching a single inspection document.
        allow get: if isJobParticipant(resource.data.jobId) || isPlatformAdmin();

        // More permissive rule for listing/querying inspections. The client-side queries
        // are responsible for filtering to the correct company's inspections.
        allow list: if authed();
        
        allow update: if isJobParticipant(resource.data.jobId) || isPlatformAdmin();
        allow delete: if isPlatformAdmin();
    }

    match /reviews/{reviewId} {
        allow read: if resource.data.status == 'Approved' || isPlatformAdmin();
        allow create: if authed();
        allow update, delete: if isPlatformAdmin(); // Only admin can approve/reject/delete
    }

    // ---------------------------
    //  Admin-Only Collections
    // ---------------------------
    match /userAuditLogs/{logId} {
      allow read, write: if isPlatformAdmin();
    }
    match /jobAuditLogs/{logId} {
      allow read, write: if isPlatformAdmin();
    }
    match /billingAuditLogs/{logId} {
      allow read, write: if isPlatformAdmin();
    }
    match /payments/{paymentId} {
      allow read, write: if isPlatformAdmin();
    }
    match /subscriptions/{subId} {
      allow read, write: if isPlatformAdmin();
    }
     match /jobPayments/{paymentId} {
      allow read: if authed(); // Client and Provider can see payments
      allow write: if isPlatformAdmin();
    }
    
    // Support chat - accessible by the company who created it, or an admin
    match /supportChats/{chatId} {
      allow read, write: if isCompanyMember(resource.data.companyId) || isPlatformAdmin();
      allow create: if isCompanyMember(request.resource.data.companyId);
    }
    match /supportMessages/{messageId} {
      // Need to read the thread to see who is a member
      allow read: if isCompanyMember(get(/databases/$(database)/documents/supportChats/$(resource.data.supportChatId)).data.companyId) || isPlatformAdmin();
      allow create: if isCompanyMember(get(/databases/$(database)/documents/supportChats/$(request.resource.data.supportChatId)).data.companyId) || isPlatformAdmin();
    }
  }
}
