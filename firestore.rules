
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Correctly checks the UID of the logged-in user against known admin UIDs.
      // Make sure these UIDs are correct for your Firebase project.
      return isSignedIn() && (request.auth.uid == 'i947NWP5Hfb3Tpe5P6XcrjODRIJ2' || request.auth.uid == '8ulGMzDhV1VgocwqptGCpV6Dkkl1');
    }

    function isCompanyMember(companyId) {
      // This function uses get() and should only be used in rules for read, update, delete.
      // It will fail if used in a 'create' rule during a batch write.
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == companyId;
    }

    // --------------------------------
    // Collection Rules
    // --------------------------------

    match /users/{userId} {
      // Allow admin to create any user (for seeding). Allow users to create their own account.
      allow create: if isAdmin() || isOwner(userId);
      // Allow admin or the user themselves to update/delete.
      allow update, delete: if isAdmin() || isOwner(userId);
      // Allow any signed-in user to read a profile to see who they are working with.
      allow read: if isSignedIn();
    }

    match /companies/{companyId} {
      // Allow admin to create companies. Users can create their own company during signup.
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.contactEmail == request.auth.token.email);
      // Publicly readable.
      allow read: if true;
      // Only admins can modify company data after creation.
      allow write: if isAdmin();

      match /supportChats/{chatId} {
        allow read, write: if isAdmin() || isCompanyMember(companyId);
        
        match /supportMessages/{messageId} {
          allow read, write: if isAdmin() || isCompanyMember(companyId);
        }
      }
    }
    
    match /assets/{assetId} {
      // Admin can seed. Users can create an asset if the companyId in the new asset matches their own companyId.
      // This is a safe way to check without using get().
      allow create: if isAdmin() || (isSignedIn() && isCompanyMember(request.resource.data.companyId));
      // Read/update/delete requires checking the existing document, so isCompanyMember is safe here.
      allow read, update, delete: if isAdmin() || isCompanyMember(resource.data.companyId);
      
      match /inspections/{inspectionId} {
        // Create allowed for admins or any signed-in user creating an inspection for this asset.
        allow create: if isAdmin() || isSignedIn();
        // Reads are allowed by company members or the assigned inspector.
        allow read: if isCompanyMember(get(/databases/$(database)/documents/assets/$(assetId)).data.companyId) || isOwner(resource.data.inspectorId);
        // Writes only by admin or the assigned inspector.
        allow update, delete: if isAdmin() || isOwner(resource.data.inspectorId);
      }
    }

    match /jobs/{jobId} {
      // Admin can seed. A user can create a job if the clientId in the job data is their own UID.
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.clientId == request.auth.uid);
      
      // Jobs are public to find and bid on.
      allow read: if true;
      
      function isJobClientOrProvider() {
        let job = resource.data;
        return isCompanyMember(job.clientCompanyId) || (job.awardedProviderId != null && isCompanyMember(job.awardedProviderId));
      }
      
      // Update/delete is restricted.
      allow update: if isAdmin() || isJobClientOrProvider();
      allow delete: if isAdmin() || isCompanyMember(resource.data.clientCompanyId);

      match /bids/{bidId} {
        // Admin can seed. An inspector can create a bid if they are the owner of the bid.
        allow create: if isAdmin() || (isSignedIn() && request.resource.data.inspectorId == request.auth.uid);

        function isJobClientForBid() {
           let job = get(/databases/$(database)/documents/jobs/$(jobId)).data;
           return isCompanyMember(job.clientCompanyId);
        }
        allow read: if isAdmin() || isOwner(resource.data.inspectorId) || isJobClientForBid();
        allow update, delete: if isAdmin() || isOwner(resource.data.inspectorId);
      }
      
      match /messages/{messageId} {
        // relies on get(), but this is okay as messages are not part of the initial seed.
         allow read, write: if (
          let job = get(/databases/$(database)/documents/jobs/$(jobId)).data;
          (isCompanyMember(job.clientCompanyId) || (job.awardedProviderId != null && isCompanyMember(job.awardedProviderId)))
        ) || isAdmin();
      }
    }

    match /reports/{reportId} {
        // Creating a report is tied to an existing inspection, handled by app logic.
        // Admins can seed. Any signed-in user can create a report document.
        allow create: if isAdmin() || isSignedIn();
        
        function canAccessReport() {
            let asset = get(/databases/$(database)/documents/assets/$(resource.data.assetId)).data;
            return isOwner(resource.data.inspectorId) || isCompanyMember(asset.companyId) || isOwner(resource.data.level3ApproverId);
        }
        allow read: if isAdmin() || canAccessReport();
        allow update, delete: if isAdmin() || isOwner(resource.data.inspectorId);
    }
    
    // All other collections that are either public or admin-only
    match /asset_types/{assetTypeId} { allow read: if true; allow write: if isAdmin(); }
    match /techniques/{techniqueId} { allow read: if true; allow write: if isAdmin(); }
    match /manufacturers/{manufacturerId} { allow read: if true; allow write: if isAdmin(); }
    match /equipment/{equipmentId} { allow read: if true; allow write: if isAdmin(); }
    match /defects/{defectId} { allow read, write: if isAdmin(); }
    match /subscriptions/{subscriptionId} { allow read, write: if isAdmin(); }
    match /roles_admin/{userId} { allow read, write: if isAdmin(); }
    match /payments/{paymentId} { allow read, write: if isAdmin(); }
    match /jobPayments/{paymentId} { allow read, write: if isAdmin(); }
    match /reviews/{reviewId} { allow read: if true; allow write: if isAdmin(); allow create: if isSignedIn(); }
    match /userAuditLogs/{logId} { allow read, write: if isAdmin(); }
    match /jobAuditLogs/{logId} { allow read, write: if isAdmin(); }
    match /billingAuditLogs/{logId} { allow read, write: if isAdmin(); }
  }
}
