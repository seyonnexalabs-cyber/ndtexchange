
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /***********************************************************
     * Helper Functions
     ***********************************************************/
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isPlatformAdmin() {
      // Use exists() to prevent errors if the user doc doesn't exist yet during creation.
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    function isCompanyMember(companyId) {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == companyId;
    }
    
    function isProviderMember(providerId) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.providerId == providerId;
    }

    // --- BLANKET ADMIN ACCESS ---
    // This rule grants full read/write access to any platform admin.
    // This is necessary for operations like database seeding.
    // More specific rules for other user roles are defined below.
    match /{path=**} {
      allow read, write: if isPlatformAdmin();
    }

    /***********************************************************
     * User Profile Rules (/users)
     ***********************************************************/
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create, update: if isOwner(userId);
      
      // Allow users to manage their own FCM tokens
      match /fcmTokens/{tokenId} {
        allow read, write: if isOwner(userId);
      }
    }

    /***********************************************************
     * Asset Rules (/assets)
     ***********************************************************/
    match /assets/{assetId} {
      // For now, allow any signed-in user to read/write.
      // In a real app, this would be restricted based on company/ownership.
      allow read, write: if isSignedIn();
    }

    /***********************************************************
     * Equipment Rules (/equipment)
     ***********************************************************/
    match /equipment/{equipmentId} {
      allow read, update, delete: if isProviderMember(resource.data.providerId);
      allow create: if isProviderMember(request.resource.data.providerId);
    }
    
    /***********************************************************
     * Job & Bidding Rules (/jobs, /bids)
     ***********************************************************/
    match /jobs/{jobId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.clientId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.clientId == request.auth.uid;
    }

    match /bids/{bidId} {
      allow get: if isSignedIn() && (get(/databases/$(database)/documents/jobs/$(resource.data.jobId)).data.clientId == request.auth.uid || resource.data.inspectorId == request.auth.uid);
      allow list: if isSignedIn() && get(/databases/$(database)/documents/jobs/$(request.query.jobId)).data.clientId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.inspectorId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.inspectorId == request.auth.uid;
    }

    /***********************************************************
     * Inspection & Report Rules (/inspections, /reports)
     ***********************************************************/
    match /inspections/{inspectionId} {
      allow read, write: if isSignedIn();
    }

    match /reports/{reportId} {
      allow read, write: if isSignedIn();
    }

    /***********************************************************
     * Company & Subscription Rules
     ***********************************************************/
    match /companies/{companyId} {
      allow get: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.contactEmail == request.auth.token.email;
    }

    match /subscriptions/{subscriptionId} {
      allow read: if isCompanyMember(resource.data.companyId);
    }
    
    /***********************************************************
     * Chat Rules
     ***********************************************************/
     match /chats/{chatId} {
       allow get, update: if isSignedIn() && request.auth.uid in resource.data.participants;
       allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
       
       match /messages/{messageId} {
         allow read, create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
       }
     }
     
     /***********************************************************
     * Support Chat Rules
     ***********************************************************/
     match /supportChats/{chatId} {
       allow read, update: if isOwner(resource.data.userId) || isPlatformAdmin();
       allow create: if isOwner(request.resource.data.userId);

       match /messages/{messageId} {
         allow read, create: if isOwner(get(/databases/$(database)/documents/supportChats/$(chatId)).data.userId) || isPlatformAdmin();
       }
     }
     
    /***********************************************************
     * Audit Log Rules
     ***********************************************************/
    // By default, only admins can read/write to these due to the blanket rule.
    // No one else should have access.
    match /userAuditLogs/{logId} { allow read, write: if false; }
    match /jobAuditLogs/{logId} { allow read, write: if false; }
    match /billingAuditLogs/{logId} { allow read, write: if false; }
    
    /***********************************************************
     * Payment Rules
     ***********************************************************/
    // By default, only admins can read/write to these due to the blanket rule.
    match /payments/{paymentId} { allow read, write: if false; }
    match /jobPayments/{paymentId} { allow read, write: if false; }

    /***********************************************************
     * Review Rules (/reviews)
     ***********************************************************/
    match /reviews/{reviewId} {
      allow get: if resource.data.status == 'Approved';
      allow list: if isSignedIn(); 

      function isJobClient(jobId) {
        return get(/databases/$(database)/documents/jobs/$(jobId)).data.clientId == request.auth.uid;
      }
      allow create: if isSignedIn() && isJobClient(request.resource.data.jobId) && request.resource.data.clientId == request.auth.uid;
    }
  }
}
