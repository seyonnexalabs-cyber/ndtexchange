
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /***********************************************************
     * Helper Functions
     ***********************************************************/
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isPlatformAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    function isCompanyMember(companyId) {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == companyId;
    }
    
    function isProviderMember(providerId) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.providerId == providerId;
    }

    /***********************************************************
     * User Profile Rules (/users)
     ***********************************************************/
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isPlatformAdmin();
      allow create: if isOwner(userId) || isPlatformAdmin();
      allow update: if isOwner(userId) || isPlatformAdmin();
      allow delete: if isPlatformAdmin();
    }

    /***********************************************************
     * Asset Rules (/assets)
     ***********************************************************/
    match /assets/{assetId} {
      // For now, allow any signed-in user to read/write.
      // In a real app, this would be restricted based on company/ownership.
      allow read, write: if isSignedIn();
    }

    /***********************************************************
     * Equipment Rules (/equipment)
     ***********************************************************/
    match /equipment/{equipmentId} {
      allow read, update, delete: if isProviderMember(resource.data.providerId) || isPlatformAdmin();
      allow create: if isProviderMember(request.resource.data.providerId) || isPlatformAdmin();
    }
    
    /***********************************************************
     * Job & Bidding Rules (/jobs, /bids)
     ***********************************************************/
    match /jobs/{jobId} {
      // Any signed-in user can read job postings.
      allow get, list: if isSignedIn();
      // Only the client who created the job can create or update it.
      allow create: if (isSignedIn() && request.resource.data.clientId == request.auth.uid) || isPlatformAdmin();
      allow update: if isSignedIn() && resource.data.clientId == request.auth.uid;
      // Only the client can delete their job posting (if needed).
      allow delete: if isSignedIn() && resource.data.clientId == request.auth.uid;
    }

    match /bids/{bidId} {
      // A bid can be read by the client of the job or the inspector who placed it.
      allow get: if isSignedIn() && (get(/databases/$(database)/documents/jobs/$(resource.data.jobId)).data.clientId == request.auth.uid || resource.data.inspectorId == request.auth.uid);
      // The client of the job can list all bids for their job.
      allow list: if isSignedIn() && get(/databases/$(database)/documents/jobs/$(request.query.jobId)).data.clientId == request.auth.uid;
      // An inspector can create a bid.
      allow create: if (isSignedIn() && request.resource.data.inspectorId == request.auth.uid) || isPlatformAdmin();
      // Only the inspector who created the bid can update or delete it.
      allow update, delete: if isSignedIn() && resource.data.inspectorId == request.auth.uid;
    }

    /***********************************************************
     * Inspection & Report Rules (/inspections, /reports)
     ***********************************************************/
    match /inspections/{inspectionId} {
      // For now, allow any signed-in user to read/write.
      // In a real app, access would be restricted to involved parties (client, provider).
      allow read, write: if isSignedIn();
    }

    match /reports/{reportId} {
      // For now, allow any signed-in user to read/write.
      // In a real app, access would be restricted to involved parties.
      allow read, write: if isSignedIn();
    }

    /***********************************************************
     * Company & Subscription Rules
     ***********************************************************/
    match /companies/{companyId} {
      allow get: if isSignedIn();
      allow write: if isPlatformAdmin();
    }

    match /subscriptions/{subscriptionId} {
      allow read: if isPlatformAdmin() || isCompanyMember(resource.data.companyId);
      allow write: if isPlatformAdmin();
    }
    
    /***********************************************************
     * Chat Rules
     ***********************************************************/
     match /chats/{chatId} {
       allow get, update: if isSignedIn() && request.auth.uid in resource.data.participants;
       match /messages/{messageId} {
         allow read, create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
       }
     }
     
     /***********************************************************
     * Support Chat Rules
     ***********************************************************/
     match /supportChats/{chatId} {
       allow read, update: if isOwner(resource.data.userId) || isPlatformAdmin();
       allow create: if isOwner(request.resource.data.userId) || isPlatformAdmin();
       allow delete: if isPlatformAdmin();

       match /messages/{messageId} {
         allow read, create: if isOwner(get(/databases/$(database)/documents/supportChats/$(chatId)).data.userId) || isPlatformAdmin();
       }
     }
     
    /***********************************************************
     * Audit Log Rules
     ***********************************************************/
    match /userAuditLogs/{logId} {
      allow read: if isPlatformAdmin();
      allow write: if isPlatformAdmin();
    }

    match /jobAuditLogs/{logId} {
      allow read: if isPlatformAdmin();
      allow write: if isPlatformAdmin();
    }

    match /billingAuditLogs/{logId} {
      allow read: if isPlatformAdmin();
      allow write: if isPlatformAdmin();
    }

    /***********************************************************
     * Review Rules (/reviews)
     ***********************************************************/
    match /reviews/{reviewId} {
      // Anyone can read approved reviews.
      allow get: if resource.data.status == 'Approved';
      allow list: if isSignedIn(); 

      // The client who owns the job can create a review for it.
      function isJobClient(jobId) {
        return get(/databases/$(database)/documents/jobs/$(jobId)).data.clientId == request.auth.uid;
      }
      allow create: if (isSignedIn() && isJobClient(request.resource.data.jobId) && request.resource.data.clientId == request.auth.uid) || isPlatformAdmin();

      // Only admins can update (for moderation) or delete reviews.
      allow update, delete: if isPlatformAdmin();
    }
  }
}
